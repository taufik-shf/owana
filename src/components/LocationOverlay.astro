---
interface Props {
  name: string;
  coords: string;
  warning: string;
  position?: 'left' | 'right';
}

const { name, coords, warning, position = 'left' } = Astro.props;
---

<div class:list={['location-overlay', `location-overlay--${position}`]}>
  <div class="label-border">
    <div class="label-inner">
      <div class="location-header">
        <span class="location-tag">LOC.</span>
        <span class="status-text">DISCOVERED</span>
      </div>
      
      <div class="location-main">
        <svg class="location-pin" width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path fill="none" stroke="currentColor" stroke-width="1.5" d="M12,10 C14.209139,10 16,8.209139 16,6 C16,3.790861 14.209139,2 12,2 C9.790861,2 8,3.790861 8,6 C8,8.209139 9.790861,10 12,10 Z M12,10 L12,22"/>
        </svg>
        <span class="location-name">{name}</span>
      </div>
      
      <div class="location-divider"></div>
      
      <div class="location-coords">
        <span class="coord-label">COORDS</span>
        <span class="coord-value">{coords}</span>
      </div>
      
      <div class="location-warning">
        <span class="warning-icon">!</span>
        <span>{warning}</span>
      </div>
    </div>
  </div>
</div>

<style>
  .location-overlay {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    width: max-content;
    max-width: 260px;
    animation: fadeReveal 0.5s ease-out;
  }

  .location-overlay--right {
    left: auto;
    right: 1.25rem;
  }

  .label-border {
    padding: 0;
  }

  .label-inner {
    background: rgba(26, 23, 20, 0.5);
    padding: 0.5rem 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .location-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 0.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .location-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.2em;
  }

  .status-text {
    font-family: var(--font-mono);
    font-size: 0.45rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.35);
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .location-main {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.2rem 0;
  }

  .location-pin {
    flex-shrink: 0;
    color: rgba(255, 255, 255, 0.5);
  }

  .location-name {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .location-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
    margin: 0.15rem 0;
  }

  .location-coords {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.1rem 0;
  }

  .coord-label {
    font-family: var(--font-mono);
    font-size: 0.4rem;
    color: rgba(255, 255, 255, 0.45);
    letter-spacing: 0.15em;
  }

  .coord-value {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.05em;
  }

  .location-warning {
    display: flex;
    align-items: flex-start;
    gap: 0.3rem;
    margin-top: 0.1rem;
  }

  .warning-icon {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    font-weight: 700;
    color: var(--dark);
    background: rgba(255, 255, 255, 0.65);
    width: 12px;
    height: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.05rem;
  }

  .location-warning span:last-child {
    font-family: var(--font-mono);
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.55);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }

  @keyframes fadeReveal {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .location-overlay {
      bottom: 0.75rem;
      left: 0.75rem;
      max-width: 200px;
    }

    .location-overlay--right {
      left: auto;
      right: 0.75rem;
    }

    .label-inner {
      padding: 0.5rem 0.6rem;
    }

    .location-name {
      font-size: 0.6rem;
    }

    .coord-value {
      font-size: 0.45rem;
    }

    .location-warning span:last-child {
      font-size: 0.4rem;
    }
  }
</style>
