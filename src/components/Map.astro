---
import geojson from '../assets/Sulawesi-tengah-polygon.json';

interface Props {
  locations?: Array<{
    name: string;
    coords: [number, number];
    desc: string;
  }>;
  zoom?: number;
  title?: string;
  coords?: string;
}

const { 
  locations = [], 
  zoom = 5.5, 
  title = 'Map of Central Sulawesi',
  coords = '0°32\'S 121°35\'E'
} = Astro.props;

---

<div class="map-card">
  <div class="map-header">
    <span class="map-header-title">{title}</span>
    <span class="map-header-coords">{coords}</span>
  </div>
  <div class="map-body"><div id="sulawesi-map" aria-label={`Map of ${title}`}></div></div>

</div>

<style>
  .map-card {
    background: #faf7f2;
    border-radius: 1rem;
    border: 1px solid rgba(26, 23, 20, 0.08);
    overflow: hidden;
  }

  .map-header {
    padding: 0.85rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    border-bottom: 1px solid rgba(26, 23, 20, 0.08);
    background: #efe9df;
  }

  .map-header-title,
  .map-header-coords {
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: #5a544a;
  }

  .map-header-title {
    font-size: 0.58rem;
    letter-spacing: 0.16em;
  }

  .map-header-coords {
    font-size: 0.53rem;
    letter-spacing: 0.1em;
    color: #8a8278;
  }

  .map-body {
    padding: 0;
    background: #d9d1c5;
    min-height: 300px;
  }

  #sulawesi-map {
    width: 100%;
    height: 460px;
    background: #d9d1c5;
  }

  .maplibregl-ctrl-group {
    background: var(--white) !important;
    border: 1px solid var(--light) !important;
    border-radius: 10px !important;
    box-shadow: 0 2px 12px rgba(28, 28, 24, 0.08) !important;
    overflow: hidden;
  }

  .maplibregl-popup-content {
    padding: 0 !important;
    border-radius: 12px !important;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(28, 28, 24, 0.14) !important;
    border: 1px solid var(--light) !important;
  }

  .maplibregl-popup-tip {
    display: none !important;
  }




</style>

<script define:vars={{ geojson, locations, zoom }}>
  document.addEventListener('DOMContentLoaded', () => {
    function initMap() {
      const mapTarget = document.getElementById('sulawesi-map');
      if (!mapTarget || typeof maplibregl === 'undefined') return;

      const map = new maplibregl.Map({
        container: 'sulawesi-map',
        style: {
          version: 8,
          sources: {
            'raster-tiles': {
              type: 'raster',
              tiles: [
                'https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}@2x.png'
              ],
              tileSize: 256,
              attribution: '&copy; <a href="https://carto.com/">CARTO</a>'
            },
            'sulawesi-polygon': {
              type: 'geojson',
              data: geojson
            }
          },
          layers: [
            {
              id: 'simple-tiles',
              type: 'raster',
              source: 'raster-tiles',
              minzoom: 0,
              maxzoom: 22
            },
            {
              id: 'sulawesi-polygon-fill',
              type: 'fill',
              source: 'sulawesi-polygon',
              paint: {
                'fill-color': '#6fa82f',
                'fill-opacity': 0.15
              }
            },
            {
              id: 'sulawesi-polygon-outline',
              type: 'line',
              source: 'sulawesi-polygon',
              paint: {
                'line-color': '#2a5c1a',
                'line-width': 1.5,
                'line-opacity': 0.8
              }
            }
          ]
        },
        center: [121.2, -0.95],
        zoom: zoom,
        minZoom: 5,
        maxZoom: 14,
        attributionControl: false
      });

      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');



      const pointCfg = { color: '#2A5C1A', border: '#A8D060', size: 16 };

      map.on('load', () => {
        locations.forEach((loc) => {
          const cfg = pointCfg;

          const wrap = document.createElement('div');
          wrap.style.cssText = `
            position: relative;
            width: ${cfg.size + 16}px;
            height: ${cfg.size + 16}px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
          `;

          const dot = document.createElement('div');
          dot.style.cssText = `
            width: ${cfg.size}px;
            height: ${cfg.size}px;
            background: ${cfg.color};
            border-radius: 50%;
            border: 2.5px solid ${cfg.border};
            box-shadow: 0 2px 10px rgba(28, 28, 24, 0.35);
            transition: transform 0.15s;
            position: relative;
            z-index: 1;
          `;
          wrap.appendChild(dot);

          const label = document.createElement('div');
          label.textContent = loc.name;
          label.style.cssText = `
            position: absolute;
            top: calc(100% + 4px);
            left: 50%;
            transform: translateX(-50%);
            font-family: Inter, sans-serif;
            font-size: 10px;
            font-weight: 700;
            color: #1C1C18;
            white-space: nowrap;
            background: rgba(250, 247, 242, 0.9);
            padding: 2px 6px;
            border-radius: 4px;
            pointer-events: none;
            letter-spacing: 0.2px;
            box-shadow: 0 1px 4px rgba(28, 28, 24, 0.12);
          `;
          wrap.appendChild(label);

          wrap.addEventListener('mouseenter', () => {
            dot.style.transform = 'scale(1.28)';
          });
          wrap.addEventListener('mouseleave', () => {
            dot.style.transform = 'scale(1)';
          });

          const popup = new maplibregl.Popup({
            offset: [0, -(cfg.size + 20)],
            closeButton: false,
            closeOnClick: true,
            maxWidth: '220px'
          }).setHTML(`
            <div style="font-family:Inter,sans-serif;padding:12px 16px;background:#FAF7F2;">
              <div style="font-family:'DM Serif Display',serif;font-size:15px;color:#2A5C1A;margin-bottom:5px;">${loc.name}</div>
              <div style="font-size:11px;color:#7A7A6E;line-height:1.55;">${loc.desc}</div>
            </div>
          `);

          new maplibregl.Marker({ element: wrap, anchor: 'center' })
            .setLngLat(loc.coords)
            .setPopup(popup)
            .addTo(map);
        });
      });
    }

    if (typeof maplibregl !== 'undefined') {
      initMap();
    } else {
      window.addEventListener('load', initMap);
    }
  });
</script>
