---
import geojson from '../assets/Sulawesi-tengah-polygon.json';

interface Props {
  locations?: Array<{
    name: string;
    coords: [number, number];
    desc: string;
  }>;
  zoom?: number;
  title?: string;
  coords?: string;
  center?: [number, number];
}

const { 
  locations = [], 
  zoom = 7.5, 
  title = 'Map of Central Sulawesi',
  coords = '1°42\'N 121°35\'E',
  center = [121.2, -0.95]
} = Astro.props;

---

<div class="map-card">
  <div class="map-header">
    <span class="map-header-title">{title}</span>
    <span class="map-header-coords">{coords}</span>
  </div>
  <div class="map-body"><div id="sulawesi-map" aria-label={`Map of ${title}`}></div></div>

</div>

<style>
  .map-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--white);
    border-radius: 1rem;
    border: 1px solid var(--owana-green);
    overflow: hidden;
  }

  .map-header {
    padding: 0.8rem 1rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    border-bottom: 1px solid var(--border-subtle);
    background: var(--owana-green-dark);
  }

  .map-header-title,
  .map-header-coords {
    font-family: var(--font-mono);
    text-transform: uppercase;
    color: var(--owana-green-dark);
  }

  .map-header-title {
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
  }

  .map-header-coords {
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    color: var(--owana-green-dark);
  }

  .map-body {
    flex: 1;
    padding: 0;
    background: var(--bg-map);
  }

  #sulawesi-map {
    width: 100%;
    height: 100%;
    background: var(--bg-map);
  }

  .maplibregl-ctrl-group {
    background: var(--white);
    border: 1px solid var(--light);
    border-radius: 1rem;
    box-shadow: 0 2px 12px rgba(28, 28, 24, 0.08);
    overflow: hidden;
  }

  .maplibregl-popup-content {
    padding: 0;
    border-radius: 1.2rem;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(28, 28, 24, 0.14);
    border: 1px solid var(--light);
  }

  .maplibregl-popup-tip {
    display: none;
  }

</style>

<script define:vars={{ geojson, locations, zoom, center }}>
  document.addEventListener('DOMContentLoaded', () => {
      async function initMap() {
        const mapTarget = document.getElementById('sulawesi-map');
        if (!mapTarget || typeof maplibregl === 'undefined') return;

        const res = await fetch('https://tiles.openfreemap.org/styles/positron');
        const style = await res.json();
        style.layers = style.layers.filter(l => l.type !== 'symbol');

        const map = new maplibregl.Map({
          container: 'sulawesi-map',
          style: style,
          center: center,
          zoom: zoom,
          minZoom: 3,
          maxZoom: 14,
          attributionControl: false
        });

      map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');



      const pointCfg = { color: '#636640', border: '#a9ad84', size: 16 };

      map.on('load', () => {
        map.addSource('sulawesi-polygon', {
          type: 'geojson',
          data: geojson
        });

        map.addLayer({
          id: 'sulawesi-polygon-fill',
          type: 'fill',
          source: 'sulawesi-polygon',
          paint: {
            'fill-color': '#a9ad84',
            'fill-opacity': 0.15
          }
        });

        map.addLayer({
          id: 'sulawesi-polygon-outline',
          type: 'line',
          source: 'sulawesi-polygon',
          paint: {
            'line-color': '#4e5039',
            'line-width': 1.5,
            'line-opacity': 0.8
          }
        });

        locations.forEach((loc) => {
          const cfg = pointCfg;

          const wrap = document.createElement('div');
          wrap.style.cssText = `
            position: relative;
            width: ${cfg.size + 16}px;
            height: ${cfg.size + 16}px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
          `;

          const dot = document.createElement('div');
          dot.style.cssText = `
            width: ${cfg.size}px;
            height: ${cfg.size}px;
            background: ${cfg.color};
            border-radius: 50%;
            border: 2.5px solid ${cfg.border};
            box-shadow: 0 2px 10px rgba(28, 28, 24, 0.35);
            transition: transform 0.15s;
            position: relative;
            z-index: 1;
          `;
          wrap.appendChild(dot);

          const label = document.createElement('div');
          label.textContent = loc.name;
          label.style.cssText = `
            position: absolute;
            top: 100%; 
            left: 50%;
            transform: translateX(-50%);
            font-family: var(--font-mono);
            font-size: var(--text-base);
            font-weight: 700;
            color: var(--ink);
            white-space: nowrap;
            background: rgba(250, 247, 242, 0.7);
            padding: 0.4rem 0.6rem;
            pointer-events: none;
            letter-spacing: 0.08em;
            box-shadow: 0 1px 4px rgba(28, 28, 24, 0.12);
          `;
          wrap.appendChild(label);

          wrap.addEventListener('mouseenter', () => {
            dot.style.transform = 'scale(1.28)';
          });
          wrap.addEventListener('mouseleave', () => {
            dot.style.transform = 'scale(1)';
          });

          const popup = new maplibregl.Popup({
            offset: [0, -(cfg.size + 20)],
            closeButton: false,
            closeOnClick: true,
            maxWidth: '220px'
          }).setHTML(`
            <div style="font-family:var(--font-sans);padding:1.2rem 1.6rem;background:var(--white);">
              <div style="font-family:var(--font-serif);font-size:var(--text-lg);color:var(--owana-green-dark);margin-bottom:0.4rem;">${loc.name}</div>
              <div style="font-size:var(--text-base);color:var(--mid);line-height:1.55;">${loc.desc}</div>
            </div>
          `);

          new maplibregl.Marker({ element: wrap, anchor: 'center' })
            .setLngLat(loc.coords)
            .setPopup(popup)
            .addTo(map);
        });
      });
    }

    if (typeof maplibregl !== 'undefined') {
      initMap();
    } else {
      window.addEventListener('load', initMap);
    }
  });
</script>
