---
interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<section class="section final-cta">
  <div class="wrap">
    <div class="cta-layout">
      <div class="cta-content">
        <p class="mono-label">GET IN TOUCH</p>
        <h2>Tell us your timing and interests.<br />We'll map the right route.</h2>
        <p class="cta-body">
          No forms. No bots. A real person from Sulawesi Tengah will respond within 24 hours.
        </p>
        <a class="cta-button" href={waLink} target="_blank" rel="noreferrer">
          <span>Chat on WhatsApp</span>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M7 17L17 7M17 7H7M17 7V17"/>
          </svg>
        </a>
      </div>
      <div class="cta-aside">
        <div class="cta-info">
          <span class="cta-info-label">Response time</span>
          <span class="cta-info-value">Under 24 hours</span>
        </div>
        <div class="cta-info">
          <span class="cta-info-label">Best contact</span>
          <span class="cta-info-value">WhatsApp preferred</span>
        </div>
        <div class="cta-info">
          <span class="cta-info-label">Team language</span>
          <span class="cta-info-value">English & Bahasa</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta {
    background: var(--forest);
    color: var(--white);
    padding: 6rem 0 7rem;
  }

  .cta-layout {
    display: grid;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .cta-layout {
      grid-template-columns: 1.2fr 1fr;
      gap: 5rem;
      align-items: center;
    }
  }

  .cta-content {
    display: grid;
    gap: 1.5rem;
  }

  .cta-content .mono-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime-light);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .cta-content .mono-label::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--lime-light);
  }

  .cta-content h2 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--white);
    max-width: 28ch;
    margin: 0;
  }

  .cta-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(250, 247, 242, 0.85);
    max-width: 28rem;
    margin: 0;
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.75rem;
    background: var(--lime);
    color: var(--ink);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    border-radius: 999px;
    transition: all 0.3s ease;
    margin-top: 0.5rem;
    width: fit-content;
  }

  .cta-button:hover {
    background: var(--lime-light);
    transform: translateX(4px);
  }

  .cta-button svg {
    transition: transform 0.3s ease;
  }

  .cta-button:hover svg {
    transform: translate(2px, -2px);
  }

  .cta-aside {
    display: grid;
    gap: 1.5rem;
    padding: 2rem;
    background: rgba(0, 0, 0, 0.15);
    border-radius: 1rem;
  }

  .cta-info {
    display: grid;
    gap: 0.35rem;
  }

  .cta-info-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--lime-light);
  }

  .cta-info-value {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    color: var(--white);
  }

  @media (max-width: 639px) {
    .final-cta {
      padding: 4rem 0 4.5rem;
    }

    .cta-layout {
      gap: 2.5rem;
    }

    .cta-aside {
      padding: 1.5rem;
    }
  }
</style>