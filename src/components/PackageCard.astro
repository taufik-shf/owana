---
interface Props {
  title: string;
  description: string;
  slug: string;
  waLink: string;
  image: string;
  tag?: string;
  variant?: 'featured' | 'compact' | 'standard';
  index?: number;
}

const { 
  title, 
  description, 
  slug, 
  waLink, 
  image, 
  tag, 
  variant = 'standard',
  index = 0
} = Astro.props;

const displayTag = tag || `Route ${String(index + 1).padStart(2, '0')}`;
const showDescription = variant !== 'compact';
---

<article class={`card card--${variant}`}>
  <div class="card-image-wrap">
    <img 
      class="card-image" 
      src={image} 
      alt={title}
      loading="lazy"
    />
    <div class="card-image-overlay"></div>
  </div>
  
  <div class="card-body">
    <span class="card-tag">{displayTag}</span>
    <h3 class="card-title">{title}</h3>
    
    {showDescription && (
      <p class="card-desc">{description}</p>
    )}
    
    <div class="card-links">
      <a href={slug} class="link-main">
        <span>Read more</span>
        <span class="link-dash">—</span>
      </a>
      <a href={waLink} class="link-wa" target="_blank" rel="noreferrer">
        WhatsApp
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    position: relative;
    background: var(--white);
    border: 1px solid var(--light);
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .card:hover {
    border-color: var(--dark);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(26, 23, 20, 0.1);
  }

  .card-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .card-image {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .card:hover .card-image {
    transform: scale(1.05);
  }

  .card-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(26, 23, 20, 0.4));
    pointer-events: none;
  }

  .card--featured .card-image {
    height: 320px;
  }

  .card--compact .card-image {
    height: 160px;
  }

  .card-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
  }

  .card--featured .card-body {
    padding: 2rem 2rem 1.75rem;
  }

  .card-tag {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .card--featured .card-tag {
    color: var(--forest);
  }

  .card-title {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--dark);
    margin: 0 0 0.5rem 0;
    transition: color 0.2s ease;
  }

  .card:hover .card-title {
    color: var(--forest);
  }

  .card--featured .card-title {
    font-size: 1.75rem;
    letter-spacing: -0.03em;
  }

  .card-desc {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--text);
    margin: 0 0 1.25rem 0;
    flex: 1;
  }

  .card--featured .card-desc {
    font-size: 1rem;
    max-width: 60ch;
  }

  .card-links {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid var(--light);
  }

  .card:hover .card-links {
    border-color: var(--dark);
  }

  .link-main {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.88rem;
    color: var(--dark);
    text-decoration: none;
    transition: gap 0.2s ease;
  }

  .link-main:hover {
    gap: 0.75rem;
  }

  .link-dash {
    color: var(--text);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .link-main:hover .link-dash {
    transform: translateX(4px);
    color: var(--forest);
  }

  .link-wa {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--forest);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .link-wa:hover {
    color: var(--dark);
  }

  @media (max-width: 639px) {
    .card-image {
      height: 180px;
    }

    .card--featured .card-image {
      height: 220px;
    }
  }
</style>
