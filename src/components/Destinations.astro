---
interface Props {
  destinationTeaser: Array<{
    label: string;
    name: string;
    line: string;
    image: string;
    imageSet: string;
    alt: string;
    slug: string;
  }>;
}

const { destinationTeaser } = Astro.props;
---

<section id="destinations" class="section dest">
  <div class="wrap-wide">
    <header class="dest-header">
      <div class="dest-header-text">
        <span class="mono-label">Destinations</span>
        <h2 class="dest-title">
          Four places that prove<br />Sulawesi Tengah is not one-note.
        </h2>
      </div>
      <div class="dest-arrows">
        <button class="dest-arrow" data-carousel-prev aria-label="Previous destination">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5M12 19l-7-7 7-7"/>
          </svg>
        </button>
        <button class="dest-arrow" data-carousel-next aria-label="Next destination">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </button>
      </div>
    </header>
  </div>

  <div class="dest-carousel" data-carousel>
    <div class="dest-track" data-carousel-track>
      {destinationTeaser.map((item) => (
        <article class="dest-card">
          <a href={item.slug} class="dest-card-link">
            <div class="dest-card-media">
              <img
                src={item.image}
                srcset={item.imageSet}
                sizes="(min-width: 768px) 30vw, 85vw"
                alt={item.alt}
                loading="lazy"
              />
            </div>
            <div class="dest-card-shade"></div>
            <span class="dest-card-tag">{item.label}</span>
            <div class="dest-card-body">
              <h3 class="dest-card-name">{item.name}</h3>
              <p class="dest-card-line">{item.line}</p>
              <span class="dest-card-cta">
                Read more
                <span class="dest-card-dash">—</span>
              </span>
            </div>
          </a>
        </article>
      ))}
    </div>
    <div class="dest-fade" aria-hidden="true"></div>
  </div>
</section>

<script>
  const containers = document.querySelectorAll('[data-carousel]');

  containers.forEach(container => {
    const section = container.closest('.dest');
    const track = container.querySelector('[data-carousel-track]') as HTMLElement;
    const prevBtn = section?.querySelector('[data-carousel-prev]') as HTMLButtonElement;
    const nextBtn = section?.querySelector('[data-carousel-next]') as HTMLButtonElement;
    const fade = container.querySelector('.dest-fade') as HTMLElement | null;

    if (!track || !prevBtn || !nextBtn) return;

    const getItemWidth = () => {
      const item = track.querySelector('.dest-card') as HTMLElement;
      if (!item) return 320;
      return item.offsetWidth + 16;
    };

    const scroll = (direction: 'prev' | 'next') => {
      track.scrollBy({
        left: direction === 'next' ? getItemWidth() : -getItemWidth(),
        behavior: 'smooth'
      });
    };

    prevBtn.addEventListener('click', () => scroll('prev'));
    nextBtn.addEventListener('click', () => scroll('next'));

    const updateUI = () => {
      const { scrollLeft, scrollWidth, clientWidth } = track;
      const atStart = scrollLeft <= 1;
      const atEnd = scrollWidth - scrollLeft - clientWidth <= 2;

      prevBtn.style.opacity = atStart ? '0.4' : '1';
      prevBtn.style.pointerEvents = atStart ? 'none' : 'auto';
      nextBtn.style.opacity = atEnd ? '0.4' : '1';
      nextBtn.style.pointerEvents = atEnd ? 'none' : 'auto';

      if (fade) {
        fade.style.opacity = atEnd ? '0' : '1';
      }
    };

    track.addEventListener('scroll', updateUI);
    window.addEventListener('resize', updateUI);
    updateUI();
  });
</script>

<style>
  .dest {
    background: var(--bg-warm);
  }

  .dest-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 4rem;
    gap: 2rem;
  }

  .dest-header-text {
    flex: 1;
  }

  .dest-header-text .mono-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--mid);
    margin-right: 0.6rem;
    vertical-align: middle;
  }

  .dest-title {
    font-family: var(--font-sans);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--dark);
    max-width: 48rem;
    margin: 0;
  }

  .dest-arrows {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .dest-arrow {
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    border: 1px solid var(--dark);
    background: transparent;
    color: var(--dark);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .dest-arrow:hover {
    background: var(--dark);
    color: var(--bg-warm);
  }

  .dest-arrow:active {
    transform: scale(0.95);
  }

  .dest-arrow:focus-visible {
    outline: 2px solid var(--forest);
    outline-offset: 2px;
  }

  .dest-carousel {
    position: relative;
    overflow: hidden;
  }

  .dest-track {
    display: flex;
    gap: 1.6rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0.5rem 0 2rem;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .dest-track::-webkit-scrollbar {
    display: none;
  }

  .dest-fade {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 8rem;
    background: linear-gradient(to right, rgba(239, 233, 223, 0), rgba(239, 233, 223, 0.95));
    pointer-events: none;
    z-index: 3;
    transition: opacity 0.3s ease;
  }

  .dest-card {
    flex: 0 0 auto;
    width: 28rem;
    scroll-snap-align: start;
    border-radius: 1rem;
    overflow: hidden;
    transition: transform 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.35s ease;
  }

  .dest-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 48px rgba(26, 23, 20, 0.18);
  }

  .dest-card-link {
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    height: 32rem;
    overflow: hidden;
  }

  .dest-card-media {
    position: absolute;
    inset: 0;
  }

  .dest-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
  }

  .dest-card:hover .dest-card-media img {
    transform: scale(1.05);
  }

  .dest-card-shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(26, 23, 20, 0.88) 0%,
      rgba(26, 23, 20, 0.45) 40%,
      rgba(26, 23, 20, 0.1) 70%,
      rgba(26, 23, 20, 0) 100%
    );
    pointer-events: none;
  }

  .dest-card-tag {
    position: absolute;
    top: 1.6rem;
    left: 1.6rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(26, 23, 20, 0.5);
    backdrop-filter: blur(8px);
    padding: 0.4rem 1rem;
    border-radius: 0.4rem;
    z-index: 2;
    border: 1px solid rgba(250, 247, 242, 0.15);
  }

  .dest-card-body {
    position: relative;
    z-index: 2;
    margin-top: auto;
    padding: 2rem;
  }

  .dest-card-name {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0 0 0.6rem 0;
  }

  .dest-card-line {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.7;
    color: rgba(250, 247, 242, 0.6);
    margin: 0 0 1.2rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .dest-card-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--lime);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: var(--text-sm);
    transition: gap 0.25s ease;
  }

  .dest-card:hover .dest-card-cta {
    gap: 1.2rem;
  }

  .dest-card-dash {
    transition: transform 0.25s ease;
  }

  .dest-card:hover .dest-card-dash {
    transform: translateX(4px);
  }

  @media (max-width: 76.8em) {
    .dest-card {
      width: 24rem;
    }

    .dest-card-link {
      height: 28rem;
    }
  }

  @media (max-width: 48em) {
    .dest-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.6rem;
      margin-bottom: 2.4rem;
    }

    .dest-title {
      font-size: var(--text-3xl);
    }

    .dest-card {
      width: 22rem;
    }

    .dest-card-link {
      height: 26rem;
    }

    .dest-arrow {
      width: 4rem;
      height: 4rem;
    }

    .dest-fade {
      width: 6rem;
    }
  }
</style>
