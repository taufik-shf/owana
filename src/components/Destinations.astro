---
interface Props {
  destinationTeaser: Array<{
    label: string;
    name: string;
    line: string;
    image: string;
    imageSet: string;
    alt: string;
    slug: string;
  }>;
}

const { destinationTeaser } = Astro.props;
---

<section id="destinations" class="section destinations">
  <div class="destinations-header wrap">
    <p class="mono-label">DESTINATIONS</p>
    <h2>Four places that prove Sulawesi Tengah is not one-note.</h2>
  </div>
  
  <div class="carousel-container" data-carousel>
    <div class="carousel-track" data-carousel-track>
      {
        destinationTeaser.map((item) => (
          <article class="carousel-item">
            <div class="carousel-image-wrap">
              <img 
                src={item.image} 
                srcset={item.imageSet} 
                sizes="(min-width: 768px) 30vw, 80vw" 
                alt={item.alt} 
                loading="lazy" 
              />
              <div class="carousel-overlay">
                <span class="carousel-label">{item.label}</span>
              </div>
            </div>
            <div class="carousel-content">
              <h3>{item.name}</h3>
              <p>{item.line}</p>
              <a href={item.slug} class="carousel-link">
                Explore
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
    
    <div class="carousel-hint" aria-hidden="true">
      <span>Scroll →</span>
    </div>
  </div>
  
  <div class="destinations-footer wrap">
    <a href="/destinations" class="destinations-all">
      View all destinations
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14M12 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</section>

<script>
  const containers = document.querySelectorAll('[data-carousel]');
  
  containers.forEach(container => {
    const track = container.querySelector('[data-carousel-track]') as HTMLElement;
    if (!track) return;

    let isDown = false;
    let startX: number;
    let scrollLeft: number;
    let velX = 0;
    let momentumID: number | null = null;

    const startDrag = (e: MouseEvent) => {
      isDown = true;
      track.style.cursor = 'grabbing';
      track.style.scrollBehavior = 'auto';
      startX = e.pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      cancelMomentum();
    };

    const endDrag = () => {
      isDown = false;
      track.style.cursor = 'grab';
      beginMomentum();
    };

    const drag = (e: MouseEvent) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      const prevScrollLeft = track.scrollLeft;
      track.scrollLeft = scrollLeft - walk;
      velX = track.scrollLeft - prevScrollLeft;
    };

    const beginMomentum = () => {
      cancelMomentum();
      momentumID = requestAnimationFrame(momentumLoop);
    };

    const cancelMomentum = () => {
      if (momentumID) {
        cancelAnimationFrame(momentumID);
        momentumID = null;
      }
    };

    const momentumLoop = () => {
      track.scrollLeft += velX;
      velX *= 0.95;
      if (Math.abs(velX) > 0.5) {
        momentumID = requestAnimationFrame(momentumLoop);
      }
    };

    // Mouse events
    track.addEventListener('mousedown', startDrag);
    track.addEventListener('mouseleave', endDrag);
    track.addEventListener('mouseup', endDrag);
    track.addEventListener('mousemove', drag);

    // Touch events
    track.addEventListener('touchstart', (e) => {
      isDown = true;
      startX = e.touches[0].pageX - track.offsetLeft;
      scrollLeft = track.scrollLeft;
      cancelMomentum();
    }, { passive: true });

    track.addEventListener('touchend', () => {
      isDown = false;
      beginMomentum();
    });

    track.addEventListener('touchmove', (e) => {
      if (!isDown) return;
      const x = e.touches[0].pageX - track.offsetLeft;
      const walk = (x - startX) * 1.5;
      const prevScrollLeft = track.scrollLeft;
      track.scrollLeft = scrollLeft - walk;
      velX = track.scrollLeft - prevScrollLeft;
    }, { passive: true });
  });
</script>

<style>
  .destinations {
    background: var(--bg-warm);
    padding: 6rem 0 5rem;
  }

  .destinations-header {
    margin-bottom: 3rem;
  }

  .destinations-header .mono-label {
    font-family: var(--font-mono);
    font-size: 0.64rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .destinations-header .mono-label::before {
    content: '';
    display: block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--text);
  }

  .destinations-header h2 {
    font-family: var(--font-sans);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.04em;
    color: var(--dark);
    max-width: 32rem;
    margin: 0;
  }

  .carousel-container {
    position: relative;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    padding: 0.5rem 0 2rem;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .carousel-track::-webkit-scrollbar {
    display: none;
  }

  .carousel-track:active {
    cursor: grabbing;
  }

  .carousel-hint {
    position: absolute;
    right: 2rem;
    bottom: 3rem;
    pointer-events: none;
    opacity: 0.6;
    transition: opacity 0.3s ease;
  }

  .carousel-hint span {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text);
    background: var(--bg-warm);
    padding: 0.5rem 1rem;
    border: 1px solid var(--light);
  }

  .carousel-container:hover .carousel-hint {
    opacity: 0;
  }

  .carousel-item {
    flex: 0 0 auto;
    width: 320px;
    scroll-snap-align: start;
    background: var(--white);
    border: 1px solid var(--light);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    user-select: none;
  }

  .carousel-item:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(26, 23, 20, 0.12);
  }

  .carousel-image-wrap {
    position: relative;
    overflow: hidden;
  }

  .carousel-image-wrap img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    pointer-events: none;
  }

  .carousel-item:hover .carousel-image-wrap img {
    transform: scale(1.08);
  }

  .carousel-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(26, 23, 20, 0.1) 0%, rgba(26, 23, 20, 0.5) 100%);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
    pointer-events: none;
  }

  .carousel-item:hover .carousel-overlay {
    opacity: 1;
  }

  .carousel-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: white;
    background: rgba(26, 23, 20, 0.6);
    padding: 0.4rem 0.75rem;
    backdrop-filter: blur(4px);
  }

  .carousel-content {
    padding: 1.25rem;
  }

  .carousel-content h3 {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--dark);
    margin: 0 0 0.35rem 0;
    transition: color 0.2s ease;
  }

  .carousel-item:hover .carousel-content h3 {
    color: var(--forest);
  }

  .carousel-content p {
    font-family: var(--font-sans);
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--text);
    margin: 0;
  }

  .carousel-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.85rem;
    color: var(--forest);
    text-decoration: none;
    transition: gap 0.2s ease;
    pointer-events: auto;
  }

  .carousel-link:hover {
    gap: 0.75rem;
  }

  .carousel-link svg {
    transition: transform 0.2s ease;
  }

  .carousel-link:hover svg {
    transform: translateX(3px);
  }

  .destinations-footer {
    padding-top: 1.5rem;
  }

  .destinations-all {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--dark);
    text-decoration: none;
    padding: 1rem 1.75rem;
    border: 1px solid var(--dark);
    border-radius: 999px;
    transition: all 0.3s ease;
  }

  .destinations-all:hover {
    background: var(--dark);
    color: var(--bg-warm);
  }

  .destinations-all svg {
    transition: transform 0.3s ease;
  }

  .destinations-all:hover svg {
    transform: translateX(4px);
  }

  @media (min-width: 768px) {
    .carousel-item {
      width: 380px;
    }

    .carousel-image-wrap img {
      height: 240px;
    }
  }

  @media (max-width: 639px) {
    .destinations {
      padding: 4rem 0 3.5rem;
    }

    .carousel-item {
      width: 280px;
    }

    .carousel-image-wrap img {
      height: 180px;
    }

    .carousel-hint {
      display: none;
    }
  }
</style>
