---
interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<header class="site-header">
  <div class="wrap nav-inner">
    <a href="#top" class="wordmark" aria-label="GOWANA home">go<span>wana</span></a>

    <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <nav id="primary-nav" class="nav-links" aria-label="Primary navigation">
      <a href="#destinations">Destinations</a>
      <a href="#packages">Packages</a>
      <a href="#about">About</a>
      <a href="#conservation">Conservation</a>
      <a class="button button-small" href={waLink} target="_blank" rel="noreferrer">WhatsApp</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: transparent;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }

  .site-header.is-scrolled {
    background: rgba(28, 28, 24, 0.82);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(250, 247, 242, 0.08);
  }

  .site-header.is-scrolled .wordmark {
    color: var(--white);
  }

  .site-header.is-scrolled .nav-toggle span {
    background: var(--white);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 4.25rem;
    gap: 1rem;
  }

  .wordmark {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    color: var(--white);
    text-shadow: 0 2px 16px rgba(10, 30, 18, 0.28);
  }

  .wordmark span {
    color: var(--lime-light);
    font-style: italic;
  }

  .nav-toggle {
    display: inline-flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.22rem;
    padding: 0.35rem;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  .nav-toggle span {
    width: 1.35rem;
    height: 2px;
    background: var(--white);
  }

  .nav-links {
    position: absolute;
    top: 4.4rem;
    left: 0.75rem;
    right: 0.75rem;
    background: rgba(28, 28, 24, 0.94);
    display: flex;
    flex-direction: column;
    padding: 1rem;
    border: 1px solid rgba(250, 247, 242, 0.12);
    box-shadow: 0 18px 36px rgba(28, 28, 24, 0.35);
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.25s ease;
    gap: 0.95rem;
  }

  .nav-links.is-open {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .nav-links a {
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.02em;
    color: rgba(250, 247, 242, 0.78);
  }

  .nav-links a:hover,
  .nav-links a:focus-visible {
    color: var(--white);
  }

  .nav-links .button-small {
    padding: 0.5rem 0.8rem;
    font-size: 0.82rem;
    border-radius: 0;
  }

  @media (min-width: 768px) {
    .nav-toggle {
      display: none;
    }

    .nav-links {
      position: relative;
      top: auto;
      left: auto;
      right: auto;
      background: transparent;
      transform: none;
      transition: none;
      opacity: 1;
      pointer-events: auto;
      box-shadow: none;
      border: 0;
      padding: 0;
      flex-direction: row;
      align-items: center;
      gap: 0.45rem;
    }

    .nav-links a {
      color: rgba(250, 247, 242, 0.76);
      padding: 0.34rem 0.58rem;
    }

    .nav-links a:hover,
    .nav-links a:focus-visible {
      background: rgba(250, 247, 242, 0.1);
    }

    .nav-links .button-small {
      padding: 0.5rem 0.8rem;
      border-radius: 0;
    }

    .site-header.is-scrolled .nav-links a {
      color: rgba(250, 247, 242, 0.8);
    }
  }
</style>

<script>
  const header = document.querySelector('.site-header');
  const toggle = document.querySelector('.nav-toggle');
  const nav = document.querySelector('#primary-nav');

  const setScrollState = () => {
    if (window.scrollY > 60) {
      header?.classList.add('is-scrolled');
    } else {
      header?.classList.remove('is-scrolled');
    }
  };

  setScrollState();
  window.addEventListener('scroll', setScrollState, { passive: true });

  toggle?.addEventListener('click', () => {
    const isOpen = nav?.classList.toggle('is-open');
    toggle.setAttribute('aria-expanded', String(isOpen));
    document.body.classList.toggle('menu-open', Boolean(isOpen));
  });

  nav?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      nav.classList.remove('is-open');
      toggle?.setAttribute('aria-expanded', 'false');
      document.body.classList.remove('menu-open');
    });
  });
</script>