---
import heroImage from '../assets/home/hero.jpg';

interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<div class="hero-frame" id="top">
  <section class="hero" aria-label="GOWANA introduction">
    <div class="wrap hero-shell">
      <div class="hero-content">
        <div class="hero-left">
          <h1 class="hero-title">
            We'll Guide<br />
            <span class="hero-title-accent">You for Free.</span>
          </h1>
        </div>
        <div class="hero-right">
          <p class="hero-sub">
            First year operating.
          </p>
          <p class="hero-sub">
           Pay only for your personal expenses. 
          </p>
          <p class="hero-sub">
            Limited period only.
          </p>
          <a class="hero-cta" href={waLink} target="_blank" rel="noreferrer">
            <span>Book a tour</span>
            <svg class="hero-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="hero-images">
        <img class="hero-image" src={heroImage.src} alt="Sulawesi Tengah landscapes" loading="eager" />
      </div>
    </div>
  </section>
</div>

<style>
  .hero-frame {
    width: 100%;
    margin: 0;
    background: #efe9df;
    position: relative;
    min-height: 100vh;
  }

  .hero {
    position: relative;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    color: var(--ink);
  }

  .hero-shell {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-top: 6rem;
    padding-bottom: 3rem;
    gap: 3rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: end;
    animation: fadeUp 0.6s ease-out;
    padding-top: 3rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    gap: 0.5rem;
  }

  .hero-title {
    font-family: var(--font-sans);
    font-size: clamp(3.5rem, 7vw, 4.5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: #1a1714;
    margin: 0;
  }

  .hero-title-accent {
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 400;
    line-height: 1.65;
    color: #5a544a;
    max-width: 320px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.4rem;
    background: #1a1714;
    color: var(--cream);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-top: 0.5rem;
  }

  .hero-cta:hover {
    background: #2d2822;
    transform: translateX(4px);
  }

  .hero-cta-arrow {
    transition: transform 0.2s ease;
  }

  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(4px);
  }

  .hero-images {
    display: flex;
    justify-content: center;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 6;
    object-fit: cover;
    display: block;
    border-radius: 1.5rem;
  }

  @media (max-width: 768px) {
    .hero-shell {
      padding-top: 4rem;
      padding-bottom: 2rem;
      gap: 2rem;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .hero-right {
      align-items: flex-start;
      text-align: left;
    }

    .hero-title {
      font-size: clamp(2.5rem, 10vw, 3.5rem);
    }

    .hero-sub {
      max-width: 100%;
    }

    .hero-image {
      aspect-ratio: 16 / 9;
      border-radius: 1rem;
    }
  }

  @media (min-width: 769px) and (max-width: 1024px) {
    .hero-title {
      font-size: clamp(2.5rem, 5vw, 4rem);
    }
  }
</style>
