---
import heroImage from '../assets/home/hero.jpg';
import LocationOverlay from './LocationOverlay.astro';

interface Props {
  waLink: string;
  title: string;
  titleAccent: string;
  titleMid: string;
  titleHighlight: string;
  ctaText: string;
}

const { waLink, title, titleAccent, titleMid, titleHighlight, ctaText } = Astro.props;
---

<div class="hero-frame" id="top">
  <section class="hero" aria-label="OWANA introduction">
    <div class="wrap hero-shell">
      <div class="hero-content">
        <div class="hero-text">
          <h1 class="hero-title">
            {title} <span class="hero-title-accent">{titleAccent}</span><br />
            {titleMid} <span class="hero-title-highlight">{titleHighlight}</span>
          </h1>
          <p class="hero-sub">We don't have all the answers.<br />But we know this place is worth getting lost in.</p>
          <a class="hero-cta" href={waLink} target="_blank" rel="noreferrer">
            <span>{ctaText}</span>
            <svg class="hero-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <div class="hero-image-wrapper">
          <img class="hero-image" src={heroImage.src} alt="Paisupok Lake, Central Sulawesi" loading="eager" />
          <LocationOverlay
            name="PAISUPOK LAKE"
            coords="-1.2112° N, 122.9809° E"
            warning="WARNING: Visibility exceptional. Depth perception may be compromised in clear waters."
            position="right"
          />
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .hero-frame {
    width: 100%;
    margin: 0;
    background: var(--bg-warm);
    position: relative;
  }

  .hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    color: var(--dark);
  }

  .hero-shell {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
    align-items: center;
    animation: fadeUp 0.6s ease-out;
    padding-top: 4rem;
  }

  .hero-text {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .hero-title {
    font-family: var(--font-sans);
    font-size: clamp(3rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin: 0;
  }

  .hero-title-accent {
    font-weight: 800;
    letter-spacing: -0.03em;
    text-decoration: underline;
    text-decoration-color: var(--lime);
    text-decoration-thickness: 3px;
    text-underline-offset: 6px;
  }

  .hero-title-highlight {
    color: var(--forest);
    white-space: nowrap;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--text);
    max-width: 400px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.4rem;
    background: var(--dark);
    color: var(--bg-warm);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-top: 0.5rem;
    width: fit-content;
  }

  .hero-cta:hover {
    background: var(--dark-hover);
    transform: translateX(4px);
  }

  .hero-cta-arrow {
    transition: transform 0.2s ease;
  }

  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(4px);
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    border-radius: 1.5rem;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .hero-text {
      order: 1;
    }

    .hero-image-wrapper {
      order: 2;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-image {
      aspect-ratio: 16 / 9;
      border-radius: 1rem;
    }
  }
</style>
