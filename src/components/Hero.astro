---
import heroImage from '../assets/home/hero.jpg';
import LocationOverlay from './LocationOverlay.astro';

interface Props {
  waLink: string;
}

const { waLink } = Astro.props;
---

<div class="hero-frame" id="top">
  <section class="hero" aria-label="GOWANA introduction">
    <div class="wrap hero-shell">
      <div class="hero-content">
        <div class="hero-left">
          <h1 class="hero-title">
            Your <span class="hero-title-accent">Amateur</span><br />
            Guide to Central Sulawesi
          </h1>
        </div>
        <div class="hero-right">
          <p>
          Central Sulawesi has megalithic stones archaeologists still can't explain, 
          forest with species found nowhere else, and islands so remote the marine life is mostly untouched.
          </p>

          <p>
          Come explore it with us!!
          </p>
          
          <a class="hero-cta" href={waLink} target="_blank" rel="noreferrer">
            <span>Book a tour</span>
            <svg class="hero-cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
      </div>
      
      <div class="hero-images">
        <div class="hero-image-wrapper">
          <img class="hero-image" src={heroImage.src} alt="Paisupok Lake, Central Sulawesi" loading="eager" />
          <LocationOverlay
            name="PAISUPOK LAKE"
            coords="-1.2112° N, 122.9809° E"
            warning="WARNING: Visibility exceptional. Depth perception may be compromised in clear waters."
          />
        </div>
      </div>
    </div>
  </section>
</div>

<style>
  .hero-frame {
    width: 100%;
    margin: 0;
    background: var(--bg-warm);
    position: relative;
  }

  .hero {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    color: var(--dark);
  }

  .hero-shell {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding-top: 8rem;
    padding-bottom: 3rem;
  }

  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    animation: fadeUp 0.6s ease-out;
    padding-top: 4rem;
  }

  .hero-left {
    display: flex;
    flex-direction: column;
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    align-items: flex-end;
    justify-content: space-between;
    text-align: right;
    gap: 0.5rem;
    padding-top: 1rem;
  }

  .hero-title {
    font-family: var(--font-sans);
    font-size: clamp(3rem, 5vw, 3.5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin: 0;
  }

  .hero-title-accent {
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .hero-sub {
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.65;
    color: var(--text);
    max-width: 320px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.9rem 1.4rem;
    background: var(--dark);
    color: var(--bg-warm);
    font-family: var(--font-sans);
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 999px;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-top: 0.5rem;
  }

  .hero-cta:hover {
    background: var(--dark-hover);
    transform: translateX(4px);
  }

  .hero-cta-arrow {
    transition: transform 0.2s ease;
  }

  .hero-cta:hover .hero-cta-arrow {
    transform: translateX(4px);
  }

  .hero-images {
    display: flex;
    justify-content: center;
    padding-top: 2rem;
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
  }

  .hero-image {
    width: 100%;
    aspect-ratio: 16 / 3;
    object-fit: cover;
    display: block;
    border-radius: 1.5rem;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .hero-content {
      grid-template-columns: 1fr;
    }

    .hero-right {
      align-items: flex-start;
      text-align: left;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-image {
      aspect-ratio: 16 / 9;
      border-radius: 1rem;
    }
  }
</style>
