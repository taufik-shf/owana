---
import Map from './Map.astro';
import FeatureCard from './FeatureCard.astro';
import { UtensilsCrossed, Activity, PawPrint, Waves, TreePine, Music } from 'lucide';

interface Feature {
  icon: string;
  title: string;
  desc: string;
}

// Helper to convert lucide icon arrays to SVG strings
const createIconSvg = (icon: number[][][], size = 18, strokeWidth = 1.5): string => {
  const paths = icon.map(([tag, attrs]) => {
    const attrStr = Object.entries(attrs)
      .map(([k, v]) => `${k}="${v}"`)
      .join(' ');
    return `<${tag} ${attrStr}/>`;
  }).join('');

  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="${strokeWidth}" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
};

const features: Feature[] = [
  {
    icon: createIconSvg(UtensilsCrossed as number[][][]),
    title: 'Local Cuisine',
    desc: 'Bali food is great. But you haven\'t eat ours yet.'
  },
  {
    icon: createIconSvg(Activity as number[][][]),
    title: 'Active Tectonics',
    desc: 'We get earthquakes like others get rain. The locals call it ayun-ayun — rocking to sleep.'
  },
  {
    icon: createIconSvg(PawPrint as number[][][]),
    title: 'Endemic Species',
    desc: '70+ species found nowhere else. Beware of the pig that looks like a deer!'
  },
  {
    icon: createIconSvg(Waves as number[][][]),
    title: 'Pristine Waters',
    desc: 'The water is so clear it looks fake. It\'s not.'
  },
  {
    icon: createIconSvg(TreePine as number[][][]),
    title: 'Wild Interior',
    desc: 'Forests so thick, even the trails don\'t want to be found.'
  },
  {
    icon: createIconSvg(Music as number[][][]),
    title: 'Living Heritage',
    desc: 'Stone statues no one can explain. People living on water. And an open invitation for ba dero.'
  }
];
---

<section id="about" class="section about">
  <div class="wrap">

    <p class="mono-label">Discover</p>
    <h2 class="about-title">Central Sulawesi</h2>

    <div class="about-split">
      <div class="about-map">
        <Map locations={[{ name: 'Palu', coords: [119.8707, -0.8917], desc: 'Provincial capital of Central Sulawesi' }]} />
      </div>

      <div class="about-content">
        <p class="about-body">
        We've been to many places in Indonesia — they're all beautiful, 
        and so is our hometown. Central Sulawesi has a lot of stories to tell. 
        From how it was born, what it holds beneath the surface, 
        the mystery of an ancient civilisation no one has fully explained,
        a land rich in minerals and biodiversity — and the best food in Indonesia 
        (our biased opinion —  but seriously try it)
        </p>

        <div class="about-stats">
          <div class="stat">
            <span class="stat-num">3</span>
            <span class="stat-label">Tectonic plates</span>
          </div>
          <div class="stat">
            <span class="stat-num">70+</span>
            <span class="stat-label">Endemic Species</span>
          </div>
          <div class="stat">
            <span class="stat-num">40+</span>
            <span class="stat-label">Spoken Languages</span>
          </div>
          <div class="stat">
            <span class="stat-num">#1</span>
            <span class="stat-label">Nickel Producer</span>
          </div>
        </div>

        <div class="feature-grid">
          {features.map((f) => (
            <FeatureCard icon={f.icon} title={f.title} desc={f.desc} />
          ))}
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .about {
    background: var(--bg-warm);
    padding: 5rem 0 6rem;
  }

  /* ---- title ---- */

  .about .mono-label {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-bottom: 1rem;
  }

  .about .mono-label::before {
    content: '';
    display: inline-block;
    width: 1.5rem;
    height: 1.5px;
    background: var(--text);
  }

  .about-title {
    font-family: var(--font-sans);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 2rem;
  }

  .about-split {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 3rem;
    align-items: stretch;
  }

  .about-map {
    position: sticky;
    top: 6rem;
    border-radius: 0.875rem;
    overflow: hidden;
    border: 1px solid var(--border);
    height: 100%;
    display: flex;
  }

  .about-map :global(.map-card) {
    flex: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
    border-radius: 0;
    border: none;
  }

  .about-map :global(.map-body) {
    flex: 1;
    min-height: 0;
  }

  .about-map :global(#sulawesi-map) {
    height: 100%;
  }

  .about-body {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 1.5rem;
  }

  .about-tagline {
    margin: 0;
    padding-left: 1.25rem;
    border-left: 2px solid var(--dark);
    font-family: var(--font-sans);
    font-style: italic;
    font-size: 1.1rem;
    line-height: 1.6;
    color: var(--dark);
  }

/* ---- stats ---- */
   .about-stats {
     display: flex;
     flex-wrap: nowrap;
     gap: 2.5rem;
     padding: 1.5rem 0;
     border-top: 1px solid var(--border);
     margin-bottom: 2rem;
   }

  .stat {
    display: grid;
    gap: 0.25rem;
  }

  .stat-num {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: 1.75rem;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--dark);
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 0.55rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text);
  }

   /* ---- feature cards ---- */
   .feature-grid {
     display: grid;
     grid-template-columns: repeat(3, 1fr);
     gap: 0.75rem;
   }

   /* ---- responsive ---- */
   @media (max-width: 768px) {
     .about-split {
       grid-template-columns: 1fr;
     }

     .about-map {
       position: static;
       height: 400px; /* Fixed height for map when in single column layout */
     }

     .feature-grid {
       grid-template-columns: repeat(2, 1fr);
     }
   }

   @media (max-width: 480px) {
     .feature-grid {
       grid-template-columns: repeat(1, 1fr);
     }
   }
</style>
