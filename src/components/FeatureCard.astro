---
interface Props {
  icon: string;
  title: string;
  desc: string;
}

const { icon, title, desc } = Astro.props;
---

<div class="feature-card">
  <div class="feature-front">
    <span class="feature-icon" set:html={icon} />
    <span class="feature-name">{title}</span>
  </div>
  <div class="feature-back">
    <span class="feature-icon-sm" set:html={icon} />
    <p class="feature-desc">{desc}</p>
    <a href={`#${title.toLowerCase().replace(/\s+/g, '-')}`} class="feature-link">Read more</a>
  </div>
</div>

<style>
  .feature-card {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 1.2rem;
    border: 1px solid var(--border);
    border-radius: 1rem;
    cursor: default;
    text-align: center;
    min-height: 14rem;
    transition:
      border-color 0.2s ease,
      box-shadow 0.3s ease;
    overflow: hidden;
  }

  .feature-card:hover {
    border-color: var(--dark);
    box-shadow: 0 0.2rem 0.8rem rgba(26, 23, 20, 0.06);
  }

  .feature-front,
  .feature-back {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    transition: opacity 0.25s ease;
  }

  .feature-front {
    opacity: 1;
  }

  .feature-back {
    position: absolute;
    inset: 0;
    padding: 2rem 1.2rem;
    opacity: 0;
    pointer-events: none;
  }

  .feature-card:hover .feature-front {
    opacity: 0;
    pointer-events: none;
  }

  .feature-card:hover .feature-back {
    opacity: 1;
    pointer-events: auto;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 4.4rem;
    height: 4.4rem;
    color: var(--dark);
  }

  .feature-icon :global(svg) {
    width: 2rem;
    height: 2rem;
  }

  .feature-icon-sm {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--dark);
    margin-bottom: 0.4rem;
  }

  .feature-icon-sm :global(svg) {
    width: 1.2rem;
    height: 1.2rem;
  }

  .feature-name {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dark);
    line-height: 1.4;
  }

  .feature-desc {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--text);
    margin: 0;
  }

  .feature-link {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--forest);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.15s;
    margin-top: 0.8rem;
    cursor: pointer;
  }

  .feature-link:hover {
    border-bottom-color: var(--forest);
  }

  @media (max-width: 48em) {
    .feature-card {
      flex-direction: column;
      min-height: auto;
      padding: 1.6rem;
      align-items: stretch;
    }

    .feature-front,
    .feature-back {
      position: static;
      opacity: 1;
      pointer-events: auto;
      display: block;
      width: 100%;
    }

    .feature-card:hover .feature-front,
    .feature-card:hover .feature-back {
      opacity: 1;
    }

    .feature-icon {
      margin: 0 auto 0.8rem;
    }

    .feature-icon-sm {
      display: none;
    }

    .feature-name,
    .feature-desc,
    .feature-link {
      display: block;
      width: 100%;
      text-align: left;
    }

    .feature-name {
      margin-bottom: 0.8rem;
      text-align: center;
    }

    .feature-desc {
      margin-bottom: 0.8rem;
    }

    .feature-link {
      margin-top: 0;
    }
  }
</style>
