---

import Map from './Map.astro';
import FeatureCard from './FeatureCard.astro';
import { UtensilsCrossed, Activity, PawPrint, Waves, TreePine, Music } from 'lucide';

interface Feature {
  icon: string;
  title: string;
  desc: string;
}

// Helper to convert lucide icon arrays to SVG strings
const createIconSvg = (icon: number[][][], size = 18, strokeWidth = 1.5): string => {
  const paths = icon.map(([tag, attrs]) => {
    const attrStr = Object.entries(attrs)
      .map(([k, v]) => `${k}="${v}"`)
      .join(' ');
    return `<${tag} ${attrStr}/>`;
  }).join('');

  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="${strokeWidth}" stroke-linecap="round" stroke-linejoin="round">${paths}</svg>`;
};

const features: Feature[] = [
  {
    icon: createIconSvg(UtensilsCrossed as number[][][]),
    title: 'Local Cuisine',
    desc: 'Bali food is great. But you haven\'t eat ours yet.'
  },
  {
    icon: createIconSvg(Activity as number[][][]),
    title: 'Active Tectonics',
    desc: 'We get earthquakes like others get rain. The locals call it ayun-ayun — rocking to sleep.'
  },
  {
    icon: createIconSvg(PawPrint as number[][][]),
    title: 'Endemic Species',
    desc: '70+ species found nowhere else. Beware of the pig that looks like a deer!'
  },
  {
    icon: createIconSvg(Waves as number[][][]),
    title: 'Pristine Waters',
    desc: 'The water is so clear it looks fake. It\'s not.'
  },
  {
    icon: createIconSvg(TreePine as number[][][]),
    title: 'Wild Interior',
    desc: 'Forests so thick, even the trails don\'t want to be found.'
  },
  {
    icon: createIconSvg(Music as number[][][]),
    title: 'Living Heritage',
    desc: 'Stone statues no one can explain. People living on water. And an open invitation for ba dero.'
  }
];
---

<section id="about" class="section about">
  <div class="wrap-wide map-paper">
    <div class="paper-texture"></div>
    <div class="wrap">
        <div class="exploration-grid">
          <div class="exploration-map">
            <Map locations={[{ name: 'Palu', coords: [119.8707, -0.8917], desc: 'Provincial capital of Central Sulawesi' }]} zoom={4.5} />
          </div>
          
          <div class="exploration-text">
            <div class="bg-text">Central<br>Sulawesi</div>
            
            <div class="exploration-label">
              <span class="mono-label">&mdash; Understand the place</span>
            </div>
            <h2 class="about-title">Here's what you getting your self into</h2>

            <p class="about-body">
            We've been to many places in Indonesia — they're all beautiful, 
            and so is our hometown. Central Sulawesi has a lot of stories to tell. 
            From how it was born, what it holds beneath the surface, 
            the mystery of an ancient civilisation no one has fully explained,
            a land rich in minerals and biodiversity — and the best food in Indonesia 
            (our biased opinion — but seriously try it)
            </p>

            <div class="about-stats">
              <div class="stat">
                <span class="stat-num">3</span>
                <span class="stat-label">Tectonic plates</span>
              </div>
              <div class="stat">
                <span class="stat-num">70+</span>
                <span class="stat-label">Endemic Species</span>
              </div>
              <div class="stat">
                <span class="stat-num">40+</span>
                <span class="stat-label">Spoken Languages</span>
              </div>
              <div class="stat">
                <span class="stat-num">#1</span>
                <span class="stat-label">Nickel Producer</span>
              </div>
            </div>
          </div>
          
          <div class="exploration-features">
            {features.map((f) => (
              <FeatureCard icon={f.icon} title={f.title} desc={f.desc} />
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding: 6.8rem 0 8.4rem;
  }

  .map-paper {
    position: relative;
    background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-warm) 50%, var(--bg-card) 100%);
    border-radius: 1rem;
    padding: 3.6rem;
    box-shadow: 
      0 0.4rem 1.6rem rgba(26, 23, 20, 0.1),
      0 1.6rem 6.4rem rgba(26, 23, 20, 0.08);
    overflow: hidden;
  }

  .paper-texture {
    position: absolute;
    inset: 0;
    background-image: 
      url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    opacity: 0.2;
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  .exploration-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 2fr;
    grid-template-rows: auto auto;
    gap: 3.6rem;
    padding: 4rem 0;
  }

  .exploration-map {
    grid-column: 1;
    grid-row: 1;
    border: 2px solid var(--border);
    border-radius: 1rem;
    overflow: hidden;
    background: var(--bg-map);
    position: relative;
    height: 100%;
    min-height: 280px;
    display: flex;
    flex-direction: column;
  }

  .exploration-map::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px dashed var(--border-subtle);
    margin: 0.8rem;
    border-radius: 0.4rem;
    pointer-events: none;
    z-index: 10;
  }

  .exploration-map :global(.map-card) {
    border: none;
    border-radius: 0;
    background: transparent;
  }

  .exploration-map :global(.map-header) {
    background: var(--bg-warm);
    border-bottom: 1px solid var(--border-subtle);
  }

  .exploration-map :global(.map-body) {
    background: var(--bg-map);
  }

  .exploration-text {
    grid-column: 2;
    grid-row: 1;
    padding-left: 0.8rem;
    padding-top: 4.8rem;
    display: flex;
    flex-direction: column;
    justify-content: start;
    position: relative;
  }

  .bg-text {
    position: absolute;
    top: -1.2rem;
    left: -1.8rem;
    font-family: var(--font-sans);
    font-size: 12rem; 
    font-weight: 800;
    line-height: 0.85;
    color: var(--dark);
    opacity: 0.06;
    white-space: normal;
    pointer-events: none;
    letter-spacing: -0.04em;
    user-select: none;
    z-index: 0;
  }

  .exploration-label {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.2rem;
  }

  @keyframes compassSpin {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(15deg); }
  }

  .mono-label {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text);
    margin-bottom: -0.8rem;
    padding-left: 1.6rem;
  }

  .about-title {
    font-family: var(--font-sans);
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.04em;
    color: var(--dark);
    margin-bottom: 2.4rem;
    max-width: 80%;
  }

  .about-body {
    font-family: var(--font-sans);
    font-size: var(--text-md);
    font-weight: 400;
    line-height: 1.7;
    color: var(--text);
    margin-bottom: 2rem;
    max-width: 90%;
  }

  .about-stats {
    display: flex;
    gap: 4.8rem;
    background: transparent;
    border-radius: 1rem;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: start;
    text-align: center;
  }

  .stat-num {
    font-family: var(--font-sans);
    font-weight: 800;
    font-size: var(--text-2xl);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--dark);
    margin-bottom: 0.4rem;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    line-height: 1.3;
  }

  .exploration-features {
    grid-column: 1 / -1;
    grid-row: 2;
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.2rem;
    margin-top: 2rem;
    padding-top: 2.4rem;
    border-top: 1px dashed var(--border-subtle);
  }

  @media (max-width: 64em) {
    .map-paper {
      padding: 2.4rem;
    }

    .exploration-grid {
      grid-template-columns: 1fr 2fr;
      gap: 2.4rem;
    }

    .exploration-features {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 48em) {
    .map-paper {
      padding: 1.6rem;
    }

    .exploration-grid {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    .exploration-map {
      grid-column: 1;
      grid-row: 1;
      height: 100%;
      margin-bottom: 0.8rem;
    }

    .exploration-text {
      grid-column: 1;
      grid-row: 2;
      padding-left: 0;
    }

    .exploration-features {
      grid-column: 1;
      grid-row: 3;
      grid-template-columns: repeat(2, 1fr);
      margin-top: 2rem;
    }

    .about-title {
      font-size: var(--text-2xl);
    }
  }

  @media (max-width: 30em) {
    .about {
      padding: 3.2rem 0 4.8rem;
    }

    .map-paper {
      padding: 1.2rem;
      border-radius: 0.4rem;
    }

    .exploration-features {
      grid-template-columns: 1fr;
    }

    .about-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.2rem;
      padding: 1.2rem;
    }

    .exploration-map {
      height: 100%;
    }
  }
</style>
