---
import '../styles/global.scss';
import PromotionalRibbon from '../components/PromotionalRibbon.astro';

interface Props {
  title?: string;
  promotion?: {
    enabled?: boolean;
    info: string;
    cta: string;
    link?: string;
    background?: string;
    color?: string;
  };
}

const {
  title = 'OWANA | Your Amateur Guide to Central Sulawesi',
  promotion = { enabled: false, info: '', cta: '' }
} = Astro.props;

const ribbonHeight = promotion.enabled ? '2.2rem' : '0px';
const bodyClass = promotion.enabled ? 'has-ribbon' : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Central Sulawesi has megalithic stones archaeologists still can't explain, forest with species found nowhere else, and islands so remote the marine life is mostly untouched."
    />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL}site.webmanifest`} />
    <meta name="theme-color" content="#efe9df" />
    <link rel="apple-touch-icon" sizes="192x192" href={`${import.meta.env.BASE_URL}android-chrome-192x192.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;700;800&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class={bodyClass} style={`--ribbon-height: ${ribbonHeight};`}>
    <PromotionalRibbon {...promotion} />
    <slot />
    <script>
      // Update ribbon height after render and on resize
      const ribbon = document.querySelector('.promo-ribbon');
      const updateRibbonHeight = () => {
        if (!ribbon) return;
        if (ribbon.classList.contains('is-hidden')) {
          document.body.style.setProperty('--ribbon-height', '0px');
        } else {
          const height = ribbon.getBoundingClientRect().height;
          document.body.style.setProperty('--ribbon-height', `${height}px`);
        }
      };
      updateRibbonHeight();
      window.addEventListener('resize', updateRibbonHeight);
    </script>
    <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
  </body>
</html>