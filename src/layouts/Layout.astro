---
interface Props {
  title?: string;
}

const { title = 'Gowana' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Go deeper into Sulawesi Tengah" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    font-family: Inter, system-ui, sans-serif;
    background: #F2EDE4;
    color: #1C1C18;
  }
</style>
