---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Gowana - Go Deeper">
  <main>
    <h1>Go Deeper. Go Wana.</h1>
    <p>Local tours in Sulawesi Tengah, Indonesia.</p>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
  }

  h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem;
    margin-bottom: 1rem;
    color: #2A5C1A;
  }

  p {
    font-size: 1.25rem;
    color: #4b5563;
  }
</style>
