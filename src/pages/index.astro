];
---

<Layout>
  <Header waLink={waLink} />
  <Hero waLink={waLink} />
  <About />
  <Packages packageRows={packageRows} waLink={waLink} />
  <Destinations destinationTeaser={destinationTeaser} />
  <WhyUs />
  <FinalCTA waLink={waLink} />
  <Footer waLink={waLink} />
</Layout>