---
const waLink = 'https://wa.me/6282198083022';

const packageRows = [
	{
		title: 'Lore Lindu Expedition',
		description:
			'Forest routes focused on Maleo nesting grounds, Anoa signs, Babirusa habitat, and birding where 77 Sulawesi endemics are still possible.',
		slug: '/packages/lore-lindu'
	},
	{
		title: 'Togean Islands by Local Boat',
		description:
			'Stingless jellyfish lake, fishing-family homestays, and long transfer days that keep mass routes away.',
		slug: '/packages/togean-islands'
	},
	{
		title: 'Sombori and the Real Sulawesi',
		description:
			'Karst limestone channels in Morowali, clear-water crossings, and an honest look at life beyond the drone angle.',
		slug: '/packages/sombori-real-sulawesi'
	},
	{
		title: 'Luwuk, Paisupok, and Banggai Coast',
		description:
			'Waterfall stops, Danau Paisupok, and quieter coastline sections most travelers skip after one photo.',
		slug: '/packages/luwuk-paisupok-banggai-coast'
	},
	{
		title: 'Donggala Coast and Palu City',
		description:
			'A practical first route with local seafood, coastal drives, and enough context before going deeper inland.',
		slug: '/packages/donggala-palu'
	},
	{
		title: 'Pokekea Megalithic Site Walkthrough',
		description:
			'Kalamba stone vessels, carved figures, and real archaeological uncertainty explained on the ground.',
		slug: '/packages/pokekea-megalithic-site'
	},
	{
		title: 'Bada Valley, Poso Lake, and Falls',
		description:
			'Full megalithic route through rough roads, lake weather shifts, and highland villages worth slowing down for.',
		slug: '/packages/bada-poso-waterfalls'
	},
	{
		title: 'Pokekea to Bada Trek (3-5 Days)',
		description:
			'Ancient footpaths, sustained climbs, village logistics, and the kind of effort that changes your pace.',
		slug: '/packages/pokekea-bada-trek'
	}
];

const destinationTeaser = [
	{
		label: 'HIGHLAND FOREST',
		name: 'Lore Lindu National Park',
		line: 'UNESCO biosphere terrain with endemic birds, clouded mornings, and long interior access roads.',
		image:
			'https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=960&q=80',
		imageSet:
			'https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=420&q=80 420w, https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=680&q=80 680w, https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=960&q=80 960w',
		alt: 'Misty forest landscape in tropical highlands',
		slug: '/destinations/lore-lindu'
	},
	{
		label: 'ISLAND CROSSING',
		name: 'Togean Islands',
		line: 'Remote reef systems and village harbors where timing depends on boats, weather, and tides.',
		image:
			'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=960&q=80',
		imageSet:
			'https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=420&q=80 420w, https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=680&q=80 680w, https://images.unsplash.com/photo-1507525428034-b723cf961d3e?auto=format&fit=crop&w=960&q=80 960w',
		alt: 'Tropical coastline and clear sea',
		slug: '/destinations/togean'
	},
	{
		label: 'KARST BELT',
		name: 'Sombori, Morowali',
		line: 'Limestone walls, narrow channels, and coastal communities still shaping tourism on their own terms.',
		image:
			'https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=960&q=80',
		imageSet:
			'https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=420&q=80 420w, https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=680&q=80 680w, https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?auto=format&fit=crop&w=960&q=80 960w',
		alt: 'Karst islands in tropical waters',
		slug: '/destinations/sombori'
	},
	{
		label: 'MEGALITHIC VALLEYS',
		name: 'Bada and Pokekea',
		line: 'Stone statues and kalamba vessels of unknown origin reached by roads that demand patience.',
		image:
			'https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=960&q=80',
		imageSet:
			'https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=420&q=80 420w, https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=680&q=80 680w, https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=960&q=80 960w',
		alt: 'Remote valley trail with tropical terrain',
		slug: '/destinations/bada-pokekea'
	}
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Local-run, small-group journeys across Sulawesi Tengah: Lore Lindu, Togean, Sombori, and megalithic valleys."
		/>
		<title>GOWANA | Sulawesi Tengah, Indonesia</title>
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Inter:wght@400;500;700;800&family=Space+Mono:wght@400;700&display=swap"
			rel="stylesheet"
		/>
		<link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
	</head>
	<body>
		<main>
			<div class="hero-frame" id="top">
				<!-- Navigation -->
				<header class="site-header">
					<div class="wrap nav-inner">
						<a href="#top" class="wordmark" aria-label="GOWANA home">go<span>wana</span></a>

						<button class="nav-toggle" type="button" aria-expanded="false" aria-controls="primary-nav" aria-label="Toggle navigation">
							<span></span>
							<span></span>
							<span></span>
						</button>

						<nav id="primary-nav" class="nav-links" aria-label="Primary navigation">
							<a href="#destinations">Destinations</a>
							<a href="#packages">Packages</a>
							<a href="#about">About</a>
							<a href="#conservation">Conservation</a>
							<a class="button button-small" href={waLink} target="_blank" rel="noreferrer">WhatsApp</a>
						</nav>
					</div>
				</header>

				<!-- Hero -->
				<section class="hero" aria-label="GOWANA introduction">
					<div class="hero-bg" aria-hidden="true"></div>
					<div class="hero-overlay" aria-hidden="true"></div>
					<div class="hero-fade" aria-hidden="true"></div>

					<div class="wrap hero-shell">
            <div class="hero-meta">
              <div class="hero-credit">
                <div>Danau Paisupok - Sulawesi Tengah</div>
                <div>0°32'S 121°35'E</div>
                <div>Nobody talks about this place. We live here.</div>
              </div>
            </div>
						<div class="hero-content">
							<p class="hero-stamp hero-badge">
								<span class="hero-badge-dot" aria-hidden="true"></span>
								<span class="hero-badge-text">Go Deeper. Go Wana.</span>
							</p>
							<h1 class="hero-title">We'll Guide You for Free.</h1>
							<p class="hero-sub">
								First year operating. You pay for your expenses. Limited period only.
							</p>
              <span class="hero-eyebrow" aria-hidden="true"></span>
							<div class="hero-actions">
								<a class="button" href="#about">Explore Sulawesi Tengah</a>
								<a class="button button-ghost" href={waLink} target="_blank" rel="noreferrer">Chat on WhatsApp</a>
							</div>
						</div>

					</div>
				</section>

				<!-- Honest Intro -->
				<section id="about" class="section about">
					<div class="wrap about-grid">
						<div class="about-left">
							<p class="mono-label">Discover</p>
							<h2 class="about-title">Sulawesi<br /><em>Tengah</em></h2>
							<p class="about-body">
								We are local operators still learning every season, every road, and every crossing. From Poso highlands to
								Banggai coastlines, we build routes around real conditions and real communities.
							</p>
							<blockquote class="about-tagline">"Sulawesi has been waiting.<br />So have we."</blockquote>
							<div class="about-stats">
								<div class="stat">
									<span class="stat-num">13</span>
									<span class="stat-label">Kabupaten / Kota</span>
								</div>
								<div class="stat">
									<span class="stat-num">68K</span>
									<span class="stat-label">km² Area</span>
								</div>
								<div class="stat">
									<span class="stat-num">3M+</span>
									<span class="stat-label">Population</span>
								</div>
							</div>
						</div>

						<aside class="about-right" aria-label="Sulawesi Tengah route notes">
							<div class="map-card">
								<div class="map-header">
									<span class="map-header-title">Peta Wilayah - Sulawesi Tengah</span>
									<span class="map-header-coords">0°32'S 121°35'E</span>
								</div>
								<div class="map-body"><div id="sulawesi-map" aria-label="Map of Sulawesi Tengah locations"></div></div>
								<div class="map-footer">
									<div class="map-legend-item">
										<div class="map-legend-dot is-capital"></div>
										Capital
									</div>
									<div class="map-legend-item">
										<div class="map-legend-dot is-city"></div>
										City
									</div>
								</div>
							</div>

							<div class="region-cards">
								<div class="rcard">
									<div class="rcard-name">Poso</div>
									<div class="rcard-desc">Highland lakes, Tentena routes, and village-paced travel days.</div>
								</div>
								<div class="rcard">
									<div class="rcard-name">Banggai</div>
									<div class="rcard-desc">Coastal crossings, clear water, and small harbor logistics.</div>
								</div>
								<div class="rcard">
									<div class="rcard-name">Donggala</div>
									<div class="rcard-desc">West coast weather windows and long, honest road sections.</div>
								</div>
								<div class="rcard">
									<div class="rcard-name">Morowali</div>
									<div class="rcard-desc">Karst channels, river edges, and remote village support lines.</div>
								</div>
							</div>
						</aside>
					</div>
				</section>
			</div>

			<!-- Packages -->
			<section id="packages" class="section packages">
				<div class="wrap">
					<p class="mono-label">PACKAGES</p>
					<h2>Pick a route. We handle logistics, weather, and the honest bits.</h2>
					<ul class="package-list">
						{
							packageRows.map((item) => (
								<li class="package-row">
									<div>
										<h3>{item.title}</h3>
										<p>{item.description}</p>
									</div>
									<div class="package-actions">
										<a href={item.slug}>Read More</a>
										<a href={waLink} target="_blank" rel="noreferrer">Book via WA</a>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<!-- Destinations Teaser -->
			<section id="destinations" class="section destinations">
				<div class="wrap">
					<p class="mono-label">DESTINATIONS</p>
					<h2>Four places that prove Sulawesi Tengah is not one-note.</h2>
					<div class="destination-grid">
						{
							destinationTeaser.map((item) => (
								<article class="destination-item">
									<img src={item.image} srcset={item.imageSet} sizes="(min-width: 768px) 47vw, 100vw" alt={item.alt} loading="lazy" />
									<p class="space-label">{item.label}</p>
									<h3>{item.name}</h3>
									<p>{item.line}</p>
									<a href={item.slug}>Explore Destination</a>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<!-- Conservation -->
			<section id="conservation" class="section conservation">
				<div class="wrap conservation-grid">
					<div class="conservation-media">
						<img
							src="https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=960&q=80"
							srcset="https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=480&q=80 480w, https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=768&q=80 768w, https://images.unsplash.com/photo-1472396961693-142e6e269027?auto=format&fit=crop&w=1200&q=80 1200w"
							sizes="(min-width: 1024px) 42vw, 100vw"
							alt="Sulawesi forest wildlife route"
							loading="lazy"
						/>
					</div>
					<div>
						<p class="mono-label">CONSERVATION</p>
						<h2>Tour-funded protection, reported plainly.</h2>
						<p>
							A portion of every trip supports protection work in Sulawesi Tengah. No grants, no vague claims, and no pressure
							on guests to participate.
						</p>
						<p>
							Our focus is protect-first: keeping existing forest corridors standing, then documenting work with photos, routes,
							and local partner updates.
						</p>
						<blockquote>"We protect what's already standing."</blockquote>
					</div>
				</div>
			</section>

			<!-- Why GOWANA -->
			<section class="section why">
				<div class="wrap">
					<p class="mono-label">WHY GOWANA</p>
					<h2>You are right to be skeptical. Here's how we run it differently.</h2>
					<div class="why-media">
						<img
							src="https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=1400&q=80"
							srcset="https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=640&q=80 640w, https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=1024&q=80 1024w, https://images.unsplash.com/photo-1500375592092-40eb2168fd21?auto=format&fit=crop&w=1400&q=80 1400w"
							sizes="100vw"
							alt="Palm trees along tropical shoreline"
							loading="lazy"
						/>
					</div>
					<div class="why-grid">
						<article>
							<h3>No middleman markup</h3>
							<p>
								You speak with the team running your route in Sulawesi Tengah, not a broker writing from another city.
							</p>
						</article>
						<article>
							<h3>No scripted guiding</h3>
							<p>
								We brief facts clearly, then make room for real conversation when plans, weather, or local events shift the day.
							</p>
						</article>
						<article>
							<h3>No hidden fees</h3>
							<p>
								What you confirm is what you pay. If logistics change, we explain options before money changes hands.
							</p>
						</article>
						<article>
							<h3>No tourist-trap detours</h3>
							<p>
								Partners are locally run families and crews we already know, not forced stops designed for commissions.
							</p>
						</article>
					</div>
				</div>
			</section>

			<!-- Final CTA -->
			<section class="section final-cta">
				<div class="wrap cta-inner">
					<h2>Tell us your timing and interests. We'll map the right route.</h2>
					<a class="button button-light" href={waLink} target="_blank" rel="noreferrer">Chat on WhatsApp</a>
					<p>No forms. No bots. A real person from Sulawesi Tengah.</p>
				</div>
			</section>
		</main>

		<!-- Footer -->
		<footer class="site-footer">
			<div class="wrap footer-grid">
				<div>
					<p class="wordmark">GOWANA</p>
					<p>Sulawesi Tengah, Indonesia</p>
				</div>
				<nav aria-label="Footer navigation" class="footer-links">
					<a href="#destinations">Destinations</a>
					<a href="#packages">Packages</a>
					<a href="#about">About</a>
					<a href="#conservation">Conservation</a>
					<a href={waLink} target="_blank" rel="noreferrer">WhatsApp</a>
				</nav>
			</div>
			<div class="wrap footer-meta">
				<p>Proudly Amateur Since 2025. Sulawesi Tengah, Indonesia.</p>
				<p>Warning: may cause severe addiction to Sulawesi.</p>
			</div>
		</footer>

		<script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>
		<script>
			const header = document.querySelector('.site-header');
			const toggle = document.querySelector('.nav-toggle');
			const nav = document.querySelector('#primary-nav');

			const setScrollState = () => {
				if (window.scrollY > 60) {
					header?.classList.add('is-scrolled');
				} else {
					header?.classList.remove('is-scrolled');
				}
			};

			setScrollState();
			window.addEventListener('scroll', setScrollState, { passive: true });

			toggle?.addEventListener('click', () => {
				const isOpen = nav?.classList.toggle('is-open');
				toggle.setAttribute('aria-expanded', String(isOpen));
				document.body.classList.toggle('menu-open', Boolean(isOpen));
			});

			nav?.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', () => {
					nav.classList.remove('is-open');
					toggle?.setAttribute('aria-expanded', 'false');
					document.body.classList.remove('menu-open');
				});
			});

			const mapTarget = document.getElementById('sulawesi-map');
			if (mapTarget && typeof maplibregl !== 'undefined') {
				const map = new maplibregl.Map({
					container: 'sulawesi-map',
					style: 'https://tiles.openfreemap.org/styles/liberty',
					center: [121.2, -0.95],
					zoom: 6.5,
					minZoom: 5,
					maxZoom: 14,
					attributionControl: false
				});

				map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'top-right');
				map.addControl(new maplibregl.AttributionControl({ compact: true }), 'bottom-right');

				const locations = [
					{
						name: 'Palu',
						coords: [119.8707, -0.8917],
						type: 'capital',
						desc: 'Provincial capital of Sulawesi Tengah'
					},
					{
						name: 'Donggala',
						coords: [119.7442, -0.6833],
						type: 'city',
						desc: 'West coast routes and sea nomad communities'
					},
					{
						name: 'Poso',
						coords: [120.7558, -1.3967],
						type: 'city',
						desc: 'Highland lakes and Wana territory gateways'
					},
					{
						name: 'Luwuk',
						coords: [122.7925, -0.9425],
						type: 'city',
						desc: 'Banggai access point for island and coast runs'
					}
				];

				const markerCfg = {
					capital: { color: '#2A5C1A', border: '#A8D060', size: 16, pulse: '2s' },
					city: { color: '#6FA82F', border: '#FAF7F2', size: 12, pulse: '2.6s' }
				};

				map.on('load', () => {
					locations.forEach((loc) => {
						const cfg = markerCfg[loc.type];

						const wrap = document.createElement('div');
						wrap.style.cssText = `
							position: relative;
							width: ${cfg.size + 16}px;
							height: ${cfg.size + 16}px;
							display: flex;
							align-items: center;
							justify-content: center;
							cursor: pointer;
						`;

						const ring = document.createElement('div');
						ring.style.cssText = `
							position: absolute;
							top: 50%;
							left: 50%;
							width: ${cfg.size + 14}px;
							height: ${cfg.size + 14}px;
							border-radius: 50%;
							border: 2px solid ${cfg.color};
							opacity: 0;
							animation: mapPulse ${cfg.pulse} ease-out infinite;
							pointer-events: none;
						`;
						wrap.appendChild(ring);

						const dot = document.createElement('div');
						dot.style.cssText = `
							width: ${cfg.size}px;
							height: ${cfg.size}px;
							background: ${cfg.color};
							border-radius: 50%;
							border: 2.5px solid ${cfg.border};
							box-shadow: 0 2px 10px rgba(28, 28, 24, 0.35);
							transition: transform 0.15s;
							position: relative;
							z-index: 1;
						`;
						wrap.appendChild(dot);

						const label = document.createElement('div');
						label.textContent = loc.name;
						label.style.cssText = `
							position: absolute;
							top: calc(100% + 4px);
							left: 50%;
							transform: translateX(-50%);
							font-family: Inter, sans-serif;
							font-size: 10px;
							font-weight: 700;
							color: #1C1C18;
							white-space: nowrap;
							background: rgba(250, 247, 242, 0.9);
							padding: 2px 6px;
							border-radius: 4px;
							pointer-events: none;
							letter-spacing: 0.2px;
							box-shadow: 0 1px 4px rgba(28, 28, 24, 0.12);
						`;
						wrap.appendChild(label);

						wrap.addEventListener('mouseenter', () => {
							dot.style.transform = 'scale(1.28)';
						});
						wrap.addEventListener('mouseleave', () => {
							dot.style.transform = 'scale(1)';
						});

						const popup = new maplibregl.Popup({
							offset: [0, -(cfg.size + 20)],
							closeButton: false,
							closeOnClick: true,
							maxWidth: '220px'
						}).setHTML(`
							<div style="font-family:Inter,sans-serif;padding:12px 16px;background:#FAF7F2;">
								<div style="font-family:'DM Serif Display',serif;font-size:15px;color:#2A5C1A;margin-bottom:5px;">${loc.name}</div>
								<div style="font-size:11px;color:#7A7A6E;line-height:1.55;">${loc.desc}</div>
							</div>
						`);

						new maplibregl.Marker({ element: wrap, anchor: 'center' })
							.setLngLat(loc.coords)
							.setPopup(popup)
							.addTo(map);
					});
				});
			}
		</script>
	</body>
</html>

<style lang="scss">
	/* Tokens */
	:root {
		--ink: #1c1c18;
		--forest: #2a5c1a;
		--forest-2: #3d7a22;
		--lime: #6fa82f;
		--lime-light: #a8d060;
		--lime-pale: #e4f0cc;
		--cream: #f2ede4;
		--cream-2: #eae4d9;
		--white: #faf7f2;
		--light: #d8d3c8;
		--mid: #7a7a6e;
		--tan: #c8b99a;
		--rust: #8b4a2a;
	}

	$font-serif: 'DM Serif Display', serif;
	$font-sans: 'Inter', sans-serif;
	$font-mono: 'Space Mono', monospace;

	$bp-md: 768px;
	$bp-lg: 1024px;
	$bp-xl: 1280px;

	/* Mixins */
	@mixin section-space {
		padding: 4.5rem 0;

		@media (min-width: $bp-md) {
			padding: 6rem 0;
		}
	}

	@mixin container {
		width: min(1120px, calc(100% - 2.5rem));
		margin: 0 auto;
	}

	/* Base */
	* {
		box-sizing: border-box;
	}

	html,
	body {
		margin: 0;
		padding: 0;
		scroll-behavior: smooth;
	}

	body {
		font-family: $font-sans;
		background:
			radial-gradient(circle at 90% 8%, rgba(111, 168, 47, 0.14), transparent 28%),
			radial-gradient(circle at 8% 32%, rgba(139, 74, 42, 0.1), transparent 30%),
			var(--cream);
		color: var(--ink);
		line-height: 1.6;

		&.menu-open {
			overflow: hidden;
		}
	}

	img {
		display: block;
		width: 100%;
		height: auto;
	}

	a {
		color: inherit;
		text-decoration: none;
	}

	.wrap {
		@include container;
	}

	.section {
		@include section-space;
	}

	h1,
	h2,
	h3 {
		margin: 0;
		line-height: 1.15;
	}

	h1,
	h2 {
		font-family: $font-serif;
		font-weight: 400;
	}

	h3 {
		font-family: $font-sans;
		font-weight: 700;
	}

	p {
		margin: 0;
	}

	.mono-label,
	.space-label {
		font-family: $font-mono;
		font-size: 0.64rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: var(--mid);
		margin-bottom: 1rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		padding: 0.75rem 1.05rem;
		border: 1px solid var(--forest);
		background: var(--forest);
		color: var(--white);
		font-weight: 700;
		font-size: 0.93rem;
		transition: background 0.25s ease, border-color 0.25s ease;

		&:hover,
		&:focus-visible {
			background: var(--forest-2);
			border-color: var(--forest-2);
		}
	}

	.button-small {
		padding: 0.5rem 0.8rem;
		font-size: 0.84rem;
	}

	.button-ghost {
		background: transparent;
		color: var(--white);
		border-color: rgba(250, 247, 242, 0.75);

		&:hover,
		&:focus-visible {
			background: rgba(250, 247, 242, 0.15);
			border-color: var(--white);
		}
	}

	.button-light {
		background: var(--lime);
		border-color: var(--lime);
		color: var(--ink);

		&:hover,
		&:focus-visible {
			background: var(--lime-light);
			border-color: var(--lime-light);
		}
	}

	/* Navigation */
	.hero-frame {
		width: 100%;
		margin: 0;
		overflow: clip;
		background: var(--cream);
		position: relative;
	}

	.site-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 100;
		background: transparent;
		transition: background 0.4s ease, backdrop-filter 0.4s ease;

		&.is-scrolled {
			background: rgba(28, 28, 24, 0.82);
			backdrop-filter: blur(16px);
			-webkit-backdrop-filter: blur(16px);
			border-bottom: 1px solid rgba(250, 247, 242, 0.08);

			.wordmark {
				color: var(--white);
			}

			.nav-toggle span {
				background: var(--white);
			}
		}
	}

	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 4.25rem;
		gap: 1rem;
	}

	.wordmark {
		font-family: $font-serif;
		font-size: 1.4rem;
		letter-spacing: -0.01em;
		color: var(--white);
		text-shadow: 0 2px 16px rgba(10, 30, 18, 0.28);

		span {
			color: var(--lime-light);
			font-style: italic;
		}
	}

	.nav-toggle {
		display: inline-flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.22rem;
		padding: 0.35rem;
		border: 0;
		background: transparent;
		cursor: pointer;

		span {
			width: 1.35rem;
			height: 2px;
			background: var(--white);
		}
	}

	.nav-links {
		position: absolute;
		top: 4.4rem;
		left: 0.75rem;
		right: 0.75rem;
		background: rgba(28, 28, 24, 0.94);
		display: flex;
		flex-direction: column;
		padding: 1rem;
		border: 1px solid rgba(250, 247, 242, 0.12);
		box-shadow: 0 18px 36px rgba(28, 28, 24, 0.35);
		transform: translateY(-8px);
		opacity: 0;
		pointer-events: none;
		transition: transform 0.25s ease;
		gap: 0.95rem;

		&.is-open {
			transform: translateY(0);
			opacity: 1;
			pointer-events: auto;
		}

		a {
			font-weight: 500;
			font-size: 0.82rem;
			letter-spacing: 0.02em;
			color: rgba(250, 247, 242, 0.78);

			&:hover,
			&:focus-visible {
				color: var(--white);
			}
		}

		.button-small {
			padding: 0.5rem 0.8rem;
			font-size: 0.82rem;
			border-radius: 0;
		}
	}

	/* Hero */
	.hero {
		position: relative;
		width: 100%;
		height: 120vh;
		min-height: 700px;
		overflow: hidden;
		display: flex;
		color: var(--white);
	}

	.hero-shell {
		position: relative;
		z-index: 3;
		display: flex;
		flex-direction: column;
		min-height: 100%;
		padding-top: 5.2rem;
		padding-bottom: 2.6rem;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background:
      url('../assets/home/hero.jpg') center 60% / cover no-repeat;
		transform: scale(1.05);
		animation: heroZoom 18s ease-out forwards;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(160deg, rgba(10, 30, 18, 0.72) 0%, rgba(10, 30, 18, 0.38) 50%, rgba(10, 30, 18, 0.1) 80%, transparent 100%);
		z-index: 1;
	}

	.hero-fade {
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 320px;
		background: linear-gradient(to bottom, transparent 0%, rgba(242, 237, 228, 0.4) 42%, rgba(242, 237, 228, 0.85) 70%, var(--cream) 100%);
		z-index: 2;
		pointer-events: none;
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.95rem;
		animation: fadeUp 0.6s ease-out;
	}

	.hero-eyebrow {
		display: inline-block;
		width: 2.25rem;
		height: 2px;
		background: var(--lime-light);
		margin-bottom: 1.2rem;
	}

	.hero-title {
		font-size: 3rem;
		line-height: 1.02;
		text-shadow: 0 2px 24px rgba(10, 30, 18, 0.35);
		margin-bottom: 0.1rem;

		em {
			font-style: italic;
			color: var(--lime-light);
		}
	}

	.hero-sub {
		font-size: 1.2rem;
		line-height: 1.75;
		color: rgba(250, 247, 242, 0.88);
		margin-bottom: 2.6rem;
		text-shadow: 0 1px 8px rgba(10, 30, 18, 0.3);
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;

		.button {
			padding: 0.75rem 1rem;
		}

		.button-ghost {
			background: rgba(28, 28, 24, 0.25);
			border-color: rgba(250, 247, 242, 0.78);
			color: var(--white);

			&:hover,
			&:focus-visible {
				background: rgba(250, 247, 242, 0.16);
			}
		}
	}

	.hero-stamp {
		margin-top: 0.35rem;
		display: inline-flex;
		width: fit-content;
	}

	.hero-meta {
		display: flex;
		justify-content: flex-end;
		align-items: flex-end;
		gap: 1rem;
	}

	.hero-badge {
		position: static;
		display: flex;
		align-items: center;
		gap: 0.65rem;
		padding: 0.5rem 0.8rem 0.5rem 0.6rem;
		background: rgba(10, 30, 18, 0.55);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		border: 1px solid rgba(168, 208, 96, 0.25);
	}

	.hero-badge-dot {
		width: 0.5rem;
		height: 0.5rem;
		border-radius: 999px;
		background: var(--lime-light);
		animation: badgePulse 2s ease-in-out infinite;
	}

	.hero-badge-text {
		font-family: $font-mono;
		font-size: 0.55rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: rgba(250, 247, 242, 0.78);
	}

	.hero-credit {
		position: static;
    margin-top: 4rem;
		text-align: right;
		font-family: $font-mono;
		font-size: 0.55rem;
		line-height: 2;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: rgba(250, 247, 242, 0.42);
	}

	/* About */
	.about {
		background: var(--cream);
		padding: 4rem 0 5.2rem;
	}

	.about-grid {
		display: grid;
		gap: 3rem;
		align-items: start;
	}

	.about-left {
		position: static;
	}

	.about .mono-label {
		color: var(--lime);
		letter-spacing: 0.2em;
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;

		&::before {
			content: '';
			display: inline-block;
			width: 1.5rem;
			height: 1.5px;
			background: var(--lime);
		}
	}

	.about-title {
		font-size: clamp(2.35rem, 5.3vw, 3.6rem);
		line-height: 1.08;
		color: var(--forest);
		margin-bottom: 1.35rem;

		em {
			font-style: italic;
			color: var(--lime-light);
		}
	}

	.about-body {
		font-size: 0.95rem;
		line-height: 1.85;
		color: var(--mid);
		margin-bottom: 1.5rem;
		max-width: 24rem;
	}

	.about-tagline {
		margin: 0 0 1.8rem;
		padding-left: 1rem;
		border-left: 3px solid var(--tan);
		font-family: $font-serif;
		font-style: italic;
		font-size: 1.24rem;
		line-height: 1.55;
		color: var(--rust);
	}

	.about-stats {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		padding-top: 1.4rem;
		border-top: 1px solid var(--light);
	}

	.stat {
		display: grid;
		gap: 0.34rem;
	}

	.stat-num {
		font-family: $font-serif;
		font-size: 1.85rem;
		line-height: 1;
		color: var(--forest);
	}

	.stat-label {
		font-family: $font-mono;
		font-size: 0.54rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--mid);
	}

	.map-card {
		background: var(--white);
		border-radius: 1.2rem;
		border: 1px solid var(--light);
		overflow: hidden;
		box-shadow: 0 6px 40px rgba(28, 28, 24, 0.07);
	}

	.map-header {
		padding: 1rem 1.2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.6rem;
		border-bottom: 1px solid var(--light);
	}

	.map-header-title,
	.map-header-coords {
		font-family: $font-mono;
		text-transform: uppercase;
		color: var(--mid);
	}

	.map-header-title {
		font-size: 0.58rem;
		letter-spacing: 0.16em;
	}

	.map-header-coords {
		font-size: 0.53rem;
		letter-spacing: 0.1em;
		color: var(--tan);
	}

	.map-body {
		padding: 0;
		background: linear-gradient(160deg, var(--cream-2), var(--white));
	}

	#sulawesi-map {
		width: 100%;
		height: 460px;
	}

	.maplibregl-ctrl-group {
		background: var(--white) !important;
		border: 1px solid var(--light) !important;
		border-radius: 10px !important;
		box-shadow: 0 2px 12px rgba(28, 28, 24, 0.08) !important;
		overflow: hidden;
	}

	.maplibregl-popup-content {
		padding: 0 !important;
		border-radius: 12px !important;
		overflow: hidden;
		box-shadow: 0 4px 24px rgba(28, 28, 24, 0.14) !important;
		border: 1px solid var(--light) !important;
	}

	.maplibregl-popup-tip {
		display: none !important;
	}

	.map-footer {
		padding: 0.85rem 1.2rem;
		display: flex;
		align-items: center;
		gap: 1.2rem;
		border-top: 1px solid var(--light);
		flex-wrap: wrap;
	}

	.map-legend-item {
		display: flex;
		align-items: center;
		gap: 0.44rem;
		font-family: $font-mono;
		font-size: 0.52rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--mid);
	}

	.map-legend-dot {
		width: 0.58rem;
		height: 0.58rem;
		border-radius: 999px;
		flex-shrink: 0;
	}

	.map-legend-dot.is-capital {
		background: var(--forest);
	}

	.map-legend-dot.is-city {
		background: var(--lime);
	}

	.region-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.75rem;
		margin-top: 0.9rem;
	}

	.rcard {
		background: var(--cream-2);
		border: 1px solid var(--light);
		padding: 1rem;
		transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;

		&:hover {
			border-color: var(--lime);
			background: var(--lime-pale);
			transform: translateY(-2px);
		}
	}

	.rcard-name {
		font-family: $font-serif;
		font-size: 1.1rem;
		color: var(--forest);
		margin-bottom: 0.22rem;
	}

	.rcard-desc {
		font-size: 0.8rem;
		line-height: 1.55;
		color: var(--mid);
	}

	/* Packages */
	.packages {
		background: var(--cream-2);

		h2 {
			font-size: clamp(1.85rem, 6vw, 3rem);
			margin-bottom: 1.8rem;
			max-width: 24ch;
		}
	}

	.package-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: grid;
		gap: 0.8rem;
	}

	.package-row {
		position: relative;
		background: var(--white);
		border: 1px solid var(--light);
		padding: 1.25rem 1rem 1.2rem 1.2rem;
		display: grid;
		gap: 0.95rem;
		box-shadow: 0 3px 0 rgba(28, 28, 24, 0.08);
		transition: transform 0.2s ease, box-shadow 0.2s ease;

		&::before {
			content: '';
			position: absolute;
			left: 0;
			top: 0;
			bottom: 0;
			width: 4px;
			background: var(--lime);
			transform: scaleY(0);
			transform-origin: top;
			transition: transform 0.25s ease;
		}

		&:hover::before,
		&:focus-within::before {
			transform: scaleY(1);
		}

		&:hover,
		&:focus-within {
			transform: translateY(-2px);
			box-shadow: 0 8px 0 rgba(42, 92, 26, 0.16);
		}

		h3 {
			font-size: 1.12rem;
			margin-bottom: 0.5rem;
		}

		p {
			color: var(--ink);
		}
	}

	.package-actions {
		display: inline-flex;
		flex-wrap: wrap;
		gap: 0.85rem;

		a {
			font-size: 0.88rem;
			font-weight: 700;
			color: var(--forest);
			text-decoration: underline;
			text-underline-offset: 0.2em;
		}
	}

	/* Destinations */
	.destinations {
		background: var(--cream);

		h2 {
			font-size: clamp(1.85rem, 6vw, 3rem);
			margin-bottom: 1.8rem;
			max-width: 26ch;
		}
	}

	.destination-grid {
		display: grid;
		gap: 1.1rem;
	}

	.destination-item {
		padding: 1.1rem 0;
		border-top: 1px solid var(--tan);

		img {
			margin-bottom: 0.9rem;
			aspect-ratio: 16 / 10;
			object-fit: cover;
			border: 1px solid var(--light);
			filter: saturate(1.08) contrast(1.02);
			box-shadow: 5px 5px 0 rgba(61, 122, 34, 0.2);
		}

		h3 {
			font-family: $font-serif;
			font-weight: 400;
			font-size: 1.5rem;
			margin-bottom: 0.45rem;
		}

		a {
			display: inline-block;
			margin-top: 0.75rem;
			font-weight: 700;
			font-size: 0.9rem;
			color: var(--forest);
			text-decoration: underline;
			text-underline-offset: 0.2em;
		}
	}

	/* Conservation */
	.conservation {
		background: var(--cream-2);
	}

	.conservation-grid {
		display: grid;
		gap: 1.5rem;

		h2 {
			font-size: clamp(1.8rem, 5.8vw, 2.75rem);
			margin-bottom: 1rem;
		}

		p + p {
			margin-top: 0.8rem;
		}

		blockquote {
			margin: 1.1rem 0 0;
			font-family: $font-serif;
			font-size: clamp(1.35rem, 5vw, 1.95rem);
			font-style: italic;
			color: var(--forest);
		}
	}

	.conservation-media {
		border: 1px solid var(--light);
		overflow: hidden;
	}

	/* Why */
	.why {
		background: var(--cream);

		h2 {
			font-size: clamp(1.85rem, 6vw, 2.95rem);
			margin-bottom: 1.6rem;
			max-width: 24ch;
		}
	}

	.why-grid {
		display: grid;
		gap: 1rem;

		article {
			padding: 1rem 0.95rem;
			border: 1px solid var(--light);
			background: var(--white);
			box-shadow: 0 2px 0 rgba(28, 28, 24, 0.08);
		}

		article:nth-child(odd) {
			border-left: 5px solid var(--lime);
		}

		article:nth-child(even) {
			border-left: 5px solid var(--rust);
		}

		h3 {
			margin-bottom: 0.5rem;
			font-size: 1.05rem;
		}
	}

	.why-media {
		margin-bottom: 1.4rem;
		padding: 0.5rem;
		background: linear-gradient(90deg, var(--cream-2), var(--lime-pale));
		border: 1px solid var(--tan);

		img {
			aspect-ratio: 21 / 8;
			object-fit: cover;
			filter: sepia(0.12) saturate(1.05);
		}
	}

	/* Final CTA */
	.final-cta {
		background: var(--forest);
		color: var(--white);
		position: relative;

		&::after {
			content: '';
			position: absolute;
			inset: 0;
			background: radial-gradient(circle at 15% 25%, rgba(168, 208, 96, 0.16), transparent 35%);
			pointer-events: none;
		}
	}

	.cta-inner {
		display: grid;
		gap: 1rem;
		justify-items: start;

		h2 {
			font-size: clamp(2rem, 7vw, 3.3rem);
			max-width: 18ch;
		}

		p {
			font-family: $font-mono;
			font-size: 0.67rem;
			letter-spacing: 0.13em;
			text-transform: uppercase;
			opacity: 0.95;
			background: rgba(28, 28, 24, 0.25);
			padding: 0.38rem 0.52rem;
			border: 1px solid rgba(250, 247, 242, 0.25);
		}
	}

	/* Footer */
	.site-footer {
		background: var(--ink);
		color: var(--cream);
		padding: 2.4rem 0 1.3rem;
		position: relative;

		&::before {
			content: '';
			position: absolute;
			inset: 0;
			background: repeating-linear-gradient(0deg, rgba(250, 247, 242, 0.03) 0 1px, transparent 1px 5px);
			pointer-events: none;
		}
	}

	.footer-grid {
		display: grid;
		gap: 1.4rem;
		padding-bottom: 1.2rem;
		border-bottom: 1px solid rgba(242, 237, 228, 0.2);

